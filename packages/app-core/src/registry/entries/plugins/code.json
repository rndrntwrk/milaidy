{
  "id": "code",
  "name": "Code",
  "description": "A coder tools plugin for elizaOS that provides filesystem, shell, and git capabilities in a restricted/sandboxed environment.",
  "npmName": "@elizaos/plugin-code",
  "version": "2.0.0-beta.0",
  "source": "bundled",
  "tags": ["coding", "filesystem", "shell", "git", "code"],
  "config": {
    "CODER_ENABLED": {
      "type": "boolean",
      "required": false,
      "sensitive": false,
      "label": "Enabled",
      "help": "Enable or disable this feature",
      "advanced": false
    },
    "CODER_TIMEOUT": {
      "type": "number",
      "required": false,
      "sensitive": false,
      "label": "Timeout",
      "help": "Coder timeout",
      "advanced": false,
      "min": 0,
      "unit": "ms"
    },
    "CODER_ALLOWED_DIRECTORY": {
      "type": "file-path",
      "required": false,
      "sensitive": false,
      "label": "Allowed Directory",
      "help": "Allowed directory for file operations",
      "advanced": false
    },
    "CODER_FORBIDDEN_COMMANDS": {
      "type": "string",
      "required": false,
      "sensitive": false,
      "label": "Forbidden Commands",
      "help": "Comma-separated list of forbidden commands",
      "advanced": false
    }
  },
  "render": {
    "visible": true,
    "pinTo": [],
    "style": "card",
    "icon": "Puzzle",
    "group": "devtools",
    "groupOrder": 5,
    "actions": ["enable", "configure"]
  },
  "resources": {
    "homepage": "https://github.com/elizaos/eliza#readme",
    "repository": "https://github.com/elizaos/eliza"
  },
  "dependsOn": [],
  "kind": "plugin",
  "subtype": "devtools"
}
