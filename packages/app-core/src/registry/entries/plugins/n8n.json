{
  "id": "n8n",
  "name": "N8n",
  "description": "DEPRECATED: replaced by @elizaos/plugin-n8n-workflow. N8n workflow integration plugin with AI-powered plugin creation for ElizaOS.",
  "npmName": "@elizaos/plugin-n8n",
  "version": "2.0.0-beta.0",
  "source": "bundled",
  "tags": [
    "n8n",
    "llm",
    "plugin-creation",
    "anthropic",
    "claude",
    "deprecated"
  ],
  "config": {
    "N8N_HOST": {
      "type": "string",
      "required": false,
      "sensitive": false,
      "label": "N8n Host",
      "help": "n8n instance URL (e.g., https://your.n8n.cloud) (required for workflow features)",
      "advanced": false
    },
    "N8N_API_KEY": {
      "type": "secret",
      "required": false,
      "sensitive": true,
      "label": "N8n Api Key",
      "help": "n8n API key for authentication (required for workflow features)",
      "advanced": false
    },
    "CLAUDE_MODEL": {
      "type": "string",
      "required": false,
      "sensitive": false,
      "default": "claude-3-opus-20240229",
      "label": "Model",
      "help": "Claude model to use",
      "placeholder": "e.g., gpt-4o, claude-sonnet-4-20250514",
      "advanced": false
    },
    "PLUGIN_DATA_DIR": {
      "type": "file-path",
      "required": false,
      "sensitive": false,
      "default": "./data",
      "label": "Data Dir",
      "help": "Directory for plugin workspace",
      "advanced": false
    },
    "ANTHROPIC_API_KEY": {
      "type": "secret",
      "required": true,
      "sensitive": true,
      "label": "Api Key",
      "help": "API key for Anthropic Claude models",
      "advanced": false
    }
  },
  "render": {
    "visible": true,
    "pinTo": [],
    "style": "card",
    "icon": "Settings",
    "group": "devtools",
    "groupOrder": 5,
    "actions": ["enable", "configure"]
  },
  "resources": {
    "homepage": "https://elizaos.ai",
    "repository": "https://github.com/elizaos/eliza"
  },
  "dependsOn": [],
  "kind": "plugin",
  "subtype": "devtools"
}
