{
  "id": "music-library",
  "name": "Music Library",
  "description": "Music metadata, library storage, playlists, user preferences, analytics, and YouTube search for elizaOS agents.",
  "npmName": "@elizaos/plugin-music-library",
  "version": "1.0.0",
  "source": "bundled",
  "tags": [
    "music",
    "library",
    "playlists",
    "analytics",
    "audio",
    "music-library"
  ],
  "config": {
    "MUSICBRAINZ_USER_AGENT": {
      "type": "string",
      "required": false,
      "sensitive": false,
      "label": "User Agent",
      "help": "Musicbrainz user agent",
      "advanced": false
    },
    "LASTFM_API_KEY": {
      "type": "secret",
      "required": false,
      "sensitive": true,
      "label": "Api Key",
      "help": "API key for Lastfm",
      "advanced": false
    },
    "GENIUS_API_KEY": {
      "type": "secret",
      "required": false,
      "sensitive": true,
      "label": "Api Key",
      "help": "API key for Genius",
      "advanced": false
    },
    "THEAUDIODB_API_KEY": {
      "type": "secret",
      "required": false,
      "sensitive": true,
      "label": "Api Key",
      "help": "API key for Theaudiodb",
      "advanced": false
    },
    "SPOTIFY_CLIENT_ID": {
      "type": "string",
      "required": false,
      "sensitive": false,
      "label": "Client Id",
      "help": "Spotify client id",
      "advanced": false
    },
    "SPOTIFY_CLIENT_SECRET": {
      "type": "secret",
      "required": false,
      "sensitive": true,
      "label": "Client Secret",
      "help": "Secret for Spotify Client",
      "advanced": false
    },
    "MUSIC_STORAGE_DIR": {
      "type": "file-path",
      "required": false,
      "sensitive": false,
      "label": "Storage Dir",
      "help": "Directory/file path",
      "advanced": false
    },
    "MUSIC_STORAGE_HIGH_QUALITY": {
      "type": "string",
      "required": false,
      "sensitive": false,
      "label": "Storage High Quality",
      "help": "Music storage high quality",
      "advanced": false
    }
  },
  "render": {
    "visible": true,
    "pinTo": [],
    "style": "card",
    "group": "feature-other",
    "groupOrder": 12,
    "actions": ["enable", "configure"]
  },
  "resources": {
    "repository": "https://github.com/elizaos-plugins/plugin-music-library"
  },
  "dependsOn": [],
  "kind": "plugin",
  "subtype": "other"
}
