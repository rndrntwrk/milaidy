{
  "id": "music-player",
  "name": "Music Player",
  "description": "Music playback engine with queue management, cross-fading, HTTP streaming, and optional Discord voice integration.",
  "npmName": "@elizaos/plugin-music-player",
  "version": "1.0.0",
  "source": "bundled",
  "tags": [
    "music",
