{
  "id": "whatsapp",
  "name": "Whatsapp",
  "description": "A plugin for integrating WhatsApp Cloud API with applications, enabling messaging capabilities and webhook handling.",
  "npmName": "@elizaos/plugin-whatsapp",
  "version": "2.0.0-beta.0",
  "source": "bundled",
  "tags": ["whatsapp", "connector", "social", "social-chat", "messaging"],
  "config": {
    "WHATSAPP_ACCESS_TOKEN": {
      "type": "secret",
      "required": false,
      "sensitive": true,
      "label": "Access Token",
      "help": "Access token for WhatsApp Cloud API (required for cloudapi auth)",
      "advanced": false
    },
    "WHATSAPP_PHONE_NUMBER_ID": {
      "type": "string",
      "required": false,
      "sensitive": false,
      "label": "Phone Number Id",
      "help": "Phone number ID for WhatsApp Cloud API (required for cloudapi auth)",
      "advanced": false
    },
    "WHATSAPP_AUTH_METHOD": {
      "type": "string",
      "required": false,
      "sensitive": false,
      "label": "Auth Method",
      "help": "Authentication method: cloudapi or baileys",
      "advanced": false
    },
    "WHATSAPP_AUTH_DIR": {
      "type": "file-path",
      "required": false,
      "sensitive": false,
      "label": "Auth Dir",
      "help": "Directory used to persist Baileys session files (required for baileys auth)",
      "advanced": false
    },
    "WHATSAPP_PRINT_QR": {
      "type": "boolean",
      "required": false,
      "sensitive": false,
      "label": "Print Qr",
      "help": "Print QR code in terminal when using Baileys auth",
      "advanced": false
    },
    "WHATSAPP_WEBHOOK_VERIFY_TOKEN": {
      "type": "secret",
      "required": false,
      "sensitive": true,
      "label": "Webhook Verify Token",
      "help": "Webhook verification token",
      "advanced": false
    },
    "WHATSAPP_BUSINESS_ACCOUNT_ID": {
      "type": "number",
      "required": false,
      "sensitive": false,
      "label": "Business Account Id",
      "help": "Business account ID",
      "advanced": false,
      "min": 0
    },
    "WHATSAPP_API_VERSION": {
      "type": "string",
      "required": false,
      "sensitive": false,
      "label": "Api Version",
      "help": "API version string",
      "advanced": false
    },
    "WHATSAPP_DM_POLICY": {
      "type": "string",
      "required": false,
      "sensitive": false,
      "label": "Dm Policy",
      "help": "DM policy (e.g. allow, deny, allowlist)",
      "advanced": false
    },
    "WHATSAPP_GROUP_POLICY": {
      "type": "string",
      "required": false,
      "sensitive": false,
      "label": "Group Policy",
      "help": "Group message policy",
      "advanced": false
    }
  },
  "render": {
    "visible": true,
    "pinTo": [],
    "style": "setup-panel",
    "icon": "Smartphone",
    "group": "connector",
    "groupOrder": 1,
    "actions": ["enable", "configure", "setup-guide"]
  },
  "resources": {
    "homepage": "https://github.com/elizaos/eliza#readme",
    "repository": "https://github.com/elizaos/eliza",
    "setupGuideUrl": "https://docs.eliza.ai/plugin-setup-guide#whatsapp"
  },
  "dependsOn": [],
  "kind": "connector",
  "subtype": "messaging",
  "auth": {
    "kind": "token",
    "credentialKeys": ["WHATSAPP_ACCESS_TOKEN"]
  }
}
