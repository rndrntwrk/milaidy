{
  "id": "matrix",
  "name": "Matrix",
  "description": "Matrix connector for rooms, bots, and federated chat workflows.",
  "npmName": "@elizaos/plugin-matrix",
  "version": "2.0.0-beta.0",
  "source": "bundled",
  "tags": ["connector", "messaging", "matrix", "chat", "social", "social-chat"],
  "config": {
    "MATRIX_ROOMS": {
      "type": "string",
      "required": false,
      "sensitive": false,
      "label": "Rooms",
      "help": "Comma-separated room/channel list",
      "advanced": false
    },
    "MATRIX_USER_ID": {
      "type": "string",
      "required": false,
      "sensitive": false,
      "label": "User Id",
      "help": "User identifier",
      "advanced": false
    },
    "MATRIX_AUTO_JOIN": {
      "type": "boolean",
      "required": false,
      "sensitive": false,
      "label": "Auto Join",
      "help": "Automatically join/discover channels",
      "advanced": false
    },
    "MATRIX_DEVICE_ID": {
      "type": "string",
      "required": false,
      "sensitive": false,
      "label": "Device Id",
      "help": "Device identifier",
      "advanced": false
    },
    "MATRIX_ENCRYPTION": {
      "type": "boolean",
      "required": false,
      "sensitive": false,
      "label": "Encryption",
      "help": "Enable encryption",
      "advanced": false
    },
    "MATRIX_HOMESERVER": {
      "type": "string",
      "required": false,
      "sensitive": false,
      "label": "Homeserver",
      "help": "Homeserver URL",
      "advanced": false
    },
    "MATRIX_ACCESS_TOKEN": {
      "type": "secret",
      "required": true,
      "sensitive": true,
      "label": "Access Token",
      "help": "Access token for Matrix",
      "advanced": false
    },
    "MATRIX_REQUIRE_MENTION": {
      "type": "boolean",
      "required": false,
      "sensitive": false,
      "label": "Require Mention",
      "help": "Only respond when mentioned",
      "advanced": false
    }
  },
  "render": {
    "visible": false,
    "pinTo": [],
    "style": "setup-panel",
    "icon": "Link",
    "group": "connector",
    "groupOrder": 1,
    "actions": ["enable", "configure", "setup-guide"]
  },
  "resources": {
    "setupGuideUrl": "https://docs.eliza.ai/plugin-setup-guide#matrix"
  },
  "dependsOn": [],
  "kind": "connector",
  "subtype": "messaging",
  "auth": {
    "kind": "token",
    "credentialKeys": ["MATRIX_ACCESS_TOKEN"]
  }
}
