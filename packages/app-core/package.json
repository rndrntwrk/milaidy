{
  "name": "@miladyai/app-core",
  "version": "2.0.0-alpha.83",
  "description": "Shared application core for Milady shells and white-label apps.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/milady-ai/milady",
  "repository": {
    "type": "git",
    "url": "https://github.com/milady-ai/milady.git",
    "directory": "packages/app-core"
  },
  "keywords": [
    "milady",
    "app-core",
    "react",
    "elizaos"
  ],
  "main": "src/index.ts",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "bun run build:dist",
    "typecheck": "test -f ../ui/dist/index.d.ts || (cd ../ui && bun run build) && tsc --noEmit -p tsconfig.json",
    "build:dist": "test -f ../ui/dist/index.d.ts || (cd ../ui && bun run build) && rm -rf dist && tsc -p tsconfig.build.json && node ../../scripts/copy-package-assets.mjs packages/app-core src/styles src/i18n/locales && node ../../scripts/prepare-package-dist.mjs packages/app-core",
    "pack:dry-run": "cd dist && npm pack --dry-run"
  },
  "exports": {
    ".": "./src/index.ts",
    "./App": "./src/App.tsx",
    "./api": "./src/api/index.ts",
    "./api/client": "./src/api/client.ts",
    "./config": "./src/config/index.ts",
    "./types": "./src/types/index.ts",
    "./events": "./src/events/index.ts",
    "./i18n": "./src/i18n/index.ts",
    "./navigation": "./src/navigation/index.ts",
    "./hooks": "./src/hooks/index.ts",
    "./bridge": "./src/bridge/index.ts",
    "./bridge/electrobun-rpc": "./src/bridge/electrobun-rpc.ts",
    "./bridge/electrobun-runtime": "./src/bridge/electrobun-runtime.ts",
    "./state": "./src/state/index.ts",
    "./state/internal": "./src/state/internal.ts",
    "./state/persistence": "./src/state/persistence.ts",
    "./state/shell-routing": "./src/state/shell-routing.ts",
    "./components": "./src/components/index.ts",
    "./components/*": "./src/components/*",
    "./utils": "./src/utils/index.ts",
    "./utils/*": "./src/utils/*",
    "./voice": "./src/voice/index.ts",
    "./autonomy": "./src/autonomy/index.ts",
    "./chat": "./src/chat/index.ts",
    "./platform": "./src/platform/index.ts",
    "./coding": "./src/coding/index.ts",
    "./companion": "./src/components/companion/index.ts",
    "./onboarding/flow": "./src/onboarding/flow.ts",
    "./onboarding/types": "./src/onboarding/types.ts",
    "./onboarding/connection-flow": "./src/onboarding/connection-flow.ts",
    "./onboarding-config": "./src/onboarding-config.ts",
    "./providers": "./src/providers/index.ts",
    "./actions": "./src/actions/index.ts",
    "./services/steward-sidecar": "./src/services/steward-sidecar.ts",
    "./styles/base.css": "./src/styles/base.css",
    "./styles/xterm.css": "./src/styles/xterm.css",
    "./styles/onboarding-game.css": "./src/styles/onboarding-game.css",
    "./styles/styles.css": "./src/styles/styles.css",
    "./shell": "./src/shell/index.ts",
    "./styles/brand-gold.css": "./src/styles/brand-gold.css",
    "./character-catalog": "./src/character-catalog.ts",
    "./test-support/test-helpers": "./src/test-support/test-helpers.ts"
  },
  "peerDependencies": {
    "@pixiv/three-vrm": "^3.5.1",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.183.2"
  },
  "dependencies": {
    "@capacitor/core": "8.0.2",
    "@capacitor/haptics": "8.0.0",
    "@capacitor/keyboard": "8.0.0",
    "@capacitor/preferences": "^8.0.1",
    "@elizaos/core": "workspace:*",
    "@miladyai/agent": "workspace:*",
    "@miladyai/plugin-wechat": "github:milady-ai/plugin-wechat",
    "@lookingglass/webxr": "^0.6.0",
    "@miladyai/ui": "workspace:*",
    "@miladyai/vrm-utils": "workspace:*",
    "@stwd/sdk": "^0.3.0",
    "livekit-client": "^2.17.1",
    "lucide-react": "^0.575.0",
    "three": "^0.183.2",
    "zod": "^4.3.6",
    "@miladyai/shared": "workspace:*",
    "@xterm/xterm": "^5.5.0",
    "@xterm/addon-fit": "^0.10.0"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "devDependencies": {
    "@elizaos/plugin-agent-skills": "workspace:*",
    "@elizaos/plugin-plugin-manager": "workspace:*",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.183.1",
    "react-test-renderer": "^19.2.4",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
