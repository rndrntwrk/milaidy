{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "vite/client"],
    "declaration": false,
    "noEmit": true,
    "baseUrl": "../../",
    "paths": {
      "@miladyai/ui": ["./packages/ui/src/index.ts"],
      "@miladyai/ui/*": ["./packages/ui/src/*"],
      "@elizaos/agent/*": ["./node_modules/@elizaos/agent/packages/agent/src/*"]
    }
  },
  "exclude": [
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx",
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ],
  "include": ["src"]
}
