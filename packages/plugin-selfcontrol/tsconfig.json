{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": false,
    "skipLibCheck": true,
    "types": ["node", "bun"],
    "declaration": false,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@miladyai/shared": ["../shared/src/index.ts"],
      "@miladyai/shared/*": ["../shared/src/*"],
      "@miladyai/plugin-roles": ["../plugin-roles/src/index.ts"],
      "@miladyai/plugin-roles/*": ["../plugin-roles/src/*"]
    }
  },
  "include": ["src"],
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx"]
}
