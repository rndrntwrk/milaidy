{
  "name": "@miladyai/plugin-selfcontrol",
  "version": "2.0.0-alpha.83",
  "description": "Website blocking plugin for Milady.",
  "type": "module",
  "main": "src/index.ts",
  "license": "MIT",
  "homepage": "https://github.com/milady-ai/milady",
  "repository": {
    "type": "git",
    "url": "https://github.com/milady-ai/milady.git",
    "directory": "packages/plugin-selfcontrol"
  },
  "keywords": [
    "milady",
    "plugin",
    "website-blocking",
    "selfcontrol"
  ],
  "exports": {
    ".": "./src/index.ts",
    "./selfcontrol": "./src/selfcontrol.ts"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "bun run build:dist",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build:dist": "rm -rf dist && tsc -p tsconfig.build.json && node ../../scripts/prepare-package-dist.mjs packages/plugin-selfcontrol",
    "pack:dry-run": "cd dist && npm pack --dry-run"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "dependencies": {
    "@elizaos/core": "workspace:*",
    "@miladyai/shared": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
