{
  "name": "@miladyai/shared",
  "version": "2.0.0-alpha.83",
  "description": "Shared code for Milady agent and app-core.",
  "type": "module",
  "main": "src/index.ts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/milady-ai/milady.git",
    "directory": "packages/shared"
  },
  "scripts": {
    "clean": "rm -rf dist",
    "build": "bun run build:dist",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build:dist": "rm -rf dist && tsc -p tsconfig.build.json && node ../../scripts/prepare-package-dist.mjs packages/shared",
    "pack:dry-run": "cd dist && npm pack --dry-run"
  },
  "exports": {
    ".": "./src/index.ts",
    "./env-utils": "./src/env-utils.ts",
    "./runtime-env": "./src/runtime-env.ts",
    "./contracts": "./src/contracts/index.ts",
    "./contracts/apps": "./src/contracts/apps.ts",
    "./contracts/awareness": "./src/contracts/awareness.ts",
    "./contracts/config": "./src/contracts/config.ts",
    "./contracts/drop": "./src/contracts/drop.ts",
    "./contracts/onboarding": "./src/contracts/onboarding.ts",
    "./contracts/permissions": "./src/contracts/permissions.ts",
    "./contracts/service-routing": "./src/contracts/service-routing.ts",
    "./contracts/verification": "./src/contracts/verification.ts",
    "./contracts/wallet": "./src/contracts/wallet.ts",
    "./config": "./src/config/types.ts",
    "./awareness": "./src/awareness/index.ts",
    "./restart": "./src/restart.ts",
    "./spoken-text": "./src/spoken-text.ts",
    "./onboarding-presets": "./src/onboarding-presets.ts"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "dependencies": {
    "@elizaos/core": "alpha",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  }
}
