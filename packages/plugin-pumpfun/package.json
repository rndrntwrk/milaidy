{
  "name": "@milady/plugin-pumpfun-streaming",
  "description": "pump.fun RTMP streaming destination plugin for elizaOS agents",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "packageType": "plugin",
  "platform": "node",
  "license": "MIT",
  "keywords": [
    "elizaos",
    "elizaos-plugin",
    "pumpfun",
    "streaming",
    "rtmp"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/milady-ai/milady.git",
    "directory": "packages/plugin-pumpfun"
  },
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "bun": "./src/index.ts",
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "package.json"
  ],
  "dependencies": {
    "@elizaos/core": "next",
    "@milady/plugin-streaming-base": "workspace:*"
  },
  "devDependencies": {
    "typescript": "^5.9.3"
  },
  "scripts": {
    "build": "bun run build.ts",
    "test": "bun test"
  },
  "agentConfig": {
    "pluginType": "elizaos:plugin:1.0.0",
    "pluginParameters": {
      "PUMPFUN_STREAM_KEY": {
        "type": "string",
        "description": "pump.fun stream key for RTMP ingest",
        "required": true
      },
      "PUMPFUN_RTMP_URL": {
        "type": "string",
        "description": "pump.fun RTMP URL (unique per stream session)",
        "required": true
      }
    }
  }
}
