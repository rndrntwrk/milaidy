{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "allowImportingTsExtensions": false,
    "declaration": true,
    "declarationMap": true,
    "esModuleInterop": true,
    "noEmit": false,
    "outDir": "./dist",
    "paths": {},
    "resolveJsonModule": true,
    "rootDir": "../..",
    "tsBuildInfoFile": "./dist/.tsbuildinfo"
  },
  "exclude": ["src/**/*.test.ts", "src/**/*.test.tsx"],
  "include": ["src"]
}
