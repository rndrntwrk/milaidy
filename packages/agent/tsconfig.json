{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": false,
    "skipLibCheck": true,
    "types": ["node", "bun"],
    "declaration": false,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@elizaos/core": ["../typescript/src/index.node.ts"],
      "@elizaos/core/*": ["../typescript/src/*"],
      "@miladyai/plugin-selfcontrol": ["../plugin-selfcontrol/src/index.ts"],
      "@miladyai/plugin-selfcontrol/*": ["../plugin-selfcontrol/src/*"],
      "@miladyai/plugin-roles": ["../plugin-roles/src/index.ts"],
      "@miladyai/plugin-roles/*": ["../plugin-roles/src/*"]
    }
  },
  "include": ["src"]
}
