{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ES2022",
    "moduleResolution": "bundler",
    "strict": false,
    "skipLibCheck": true,
    "types": ["node", "bun"],
    "declaration": false,
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "baseUrl": ".",
    "paths": {
      "@elizaos/core": ["../../eliza/packages/typescript/src/index.node.ts"],
      "@elizaos/core/*": ["../../eliza/packages/typescript/src/*"],
      "@miladyai/plugin-selfcontrol": ["../plugin-selfcontrol/src/index.ts"],
      "@miladyai/plugin-selfcontrol/*": ["../plugin-selfcontrol/src/*"],
      "@miladyai/shared": ["../shared/src/index.ts"],
      "@miladyai/shared/*": ["../shared/src/*"]
    }
  },
  "include": ["src"]
}
