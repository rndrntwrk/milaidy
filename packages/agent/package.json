    "@elizaos/plugin-personality": "alpha",
    "@elizaos/plugin-pi-ai": "alpha",
    "@elizaos/plugin-plugin-manager": "alpha",
    "@elizaos/plugin-rolodex": "alpha",
    "@elizaos/plugin-secrets-manager": "alpha",
    "@elizaos/plugin-shell": "alpha",
    "@elizaos/plugin-sql": "alpha",
    "@elizaos/plugin-trajectory-logger": "alpha",
    "@elizaos/plugin-trust": "alpha",
    "@miladyai/plugin-selfcontrol": "workspace:*",
    "@hapi/boom": "^10.0.1",
    "@mariozechner/pi-ai": "0.52.12",
    "@miladyai/plugin-roles": "github:milady-ai/plugin-roles#5b00c49",
    "@miladyai/plugin-wechat": "github:milady-ai/plugin-wechat",
    "@miladyai/shared": "workspace:*",
    "@noble/curves": "^2.0.1",
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "dotenv": "^17.2.3",
    "drizzle-orm": "0.45.1",
    "ethers": "^6.16.0",
    "git-workspace-service": "0.4.5",
    "json5": "^2.2.3",
    "pg": "^8.16.3",
    "pino": "^10.3.1",
    "pty-manager": "1.10.2",
    "puppeteer-core": "^24.37.5",
    "qrcode": "^1.5.4",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "peerDependencies": {
    "@elizaos/signal-native": "*"
  },
  "peerDependenciesMeta": {
    "@elizaos/signal-native": {
      "optional": true
    }
  },
  "devDependencies": {
    "@ai-sdk/openai": "^3.0.47",
    "@types/node": "^25.2.0",
    "@types/pg": "^8.15.2",
    "@types/ws": "^8.18.1",
    "ai": "^6.0.134",
    "canvas": "^3.0.1",
    "sharp": "^0.33.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
