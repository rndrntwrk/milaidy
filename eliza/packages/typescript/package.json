{
  "name": "@elizaos/core",
  "version": "2.0.0-alpha.139",
  "description": "",
  "type": "module",
  "main": "./dist/index.node.js",
  "module": "./dist/index.node.js",
  "types": "./dist/index.d.ts",
  "browser": "./dist/index.browser.js",
  "sideEffects": false,
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/index.d.ts",
      "browser": {
        "types": "./dist/index.browser.d.ts",
        "import": "./dist/index.browser.js",
        "default": "./dist/index.browser.js"
      },
      "node": {
        "types": "./dist/index.node.d.ts",
        "import": "./dist/index.node.js",
        "default": "./dist/index.node.js"
      },
      "bun": {
        "types": "./dist/index.node.d.ts",
        "default": "./dist/index.node.js"
      },
      "default": "./dist/index.node.js"
    },
    "./node": {
      "types": "./dist/index.node.d.ts",
      "import": "./dist/index.node.js",
      "default": "./dist/index.node.js"
    },
    "./browser": {
      "types": "./dist/index.browser.d.ts",
      "import": "./dist/index.browser.js",
      "default": "./dist/index.browser.js"
    },
    "./roles": {
      "types": "./dist/roles.d.ts",
      "import": "./dist/roles.js",
      "default": "./dist/roles.js"
    },
    "./testing": {
      "types": "./src/testing/index.ts",
      "import": "./dist/testing/index.js",
      "default": "./dist/testing/index.js"
    },
    "./orchestrator": {
      "types": "./src/features/orchestrator/index.ts",
      "import": "./dist/node/features/orchestrator/index.js",
      "default": "./dist/node/features/orchestrator/index.js"
    },
    "./advanced-capabilities/clipboard/index": {
      "types": "./src/features/advanced-capabilities/clipboard/index.ts",
      "import": "./dist/node/features/advanced-capabilities/clipboard/index.js",
      "default": "./dist/node/features/advanced-capabilities/clipboard/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "postinstall": "node ./scripts/ensure-node-pty.mjs",
    "prebuild": "[ -d src/types/generated ] || (cd ../schemas && bunx buf generate)",
    "build": "bun run build.ts",
    "build:node": "bun run build.ts --node-only",
    "build:watch": "bun run build.ts --watch",
    "dev": "bun run build:watch",
    "clean": "rm -rf dist .turbo node_modules .turbo-tsconfig.json *.tsbuildinfo && find src -type f \\( -name '*.js' -o -name '*.d.ts' -o -name '*.d.ts.map' \\) ! -path 'src/types/generated/*' -delete 2>/dev/null || true",
    "perf:settings": "bun run scripts/perf-settings.ts",
    "test": "vitest run",
    "test:coverage": "mkdir -p coverage/.tmp && vitest run --coverage",
    "test:e2e": "npx playwright test",
    "test:e2e:smoke": "node scripts/run-e2e-smoke.mjs",
    "test:watch": "vitest",
    "lint": "bunx @biomejs/biome check --write ./src",
    "lint:check": "bunx @biomejs/biome check ./src",
    "lint:fix": "bunx @biomejs/biome check --write ./src",
    "typecheck": "tsc --noEmit -p ./tsconfig.json",
    "format": "bunx @biomejs/biome format --write ./src",
    "format:check": "bunx @biomejs/biome format ./src"
  },
  "author": "elizaOS",
  "license": "MIT",
  "devDependencies": {
    "@elizaos/plugin-elizacloud": "^2.0.0-alpha",
    "@elizaos/plugin-sql": "^2.0.0-alpha",
    "@elizaos/schemas": "workspace:*",
    "@playwright/test": "^1.52.0",
    "@types/bun": "^1.3.5",
    "@types/fast-redact": "^3.0.4",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.0.3",
    "@types/uuid": "^11.0.0",
    "@vitest/coverage-v8": "^4.0.0",
    "esbuild": "^0.25.0",
    "sharp": "^0.34.5",
    "typescript": "^5.9.3",
    "vitest": "^4.0.0"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.13",
    "@ai-sdk/google": "^3.0.8",
    "@ai-sdk/openai": "^3.0.9",
    "@anthropic-ai/sdk": "^0.32.1",
    "@bufbuild/protobuf": "^2.11.0",
    "@langchain/core": "^1.1.12",
    "@langchain/textsplitters": "^1.0.1",
    "@noble/ciphers": "^1.3.0",
    "@noble/hashes": "^1.8.0",
    "@openrouter/ai-sdk-provider": "^1.2.0",
    "@toon-format/toon": "^2.1.0",
    "adze": "^2.2.5",
    "ai": "^6.0.30",
    "dedent": "^1.7.1",
    "dotenv": "^17.2.3",
    "coding-agent-adapters": "0.16.3",
    "drizzle-orm": "^0.45.1",
    "fast-redact": "^3.5.0",
    "git-workspace-service": "0.4.5",
    "file-type": "^21.3.0",
    "glob": "^13.0.0",
    "handlebars": "^4.7.8",
    "json5": "^2.2.3",
    "mammoth": "^1.9.0",
    "markdown-it": "^14.1.0",
    "pdfjs-dist": "^5.4.530",
    "pty-console": "0.3.1",
    "pty-manager": "1.11.0",
    "pty-state-capture": "0.2.0",
    "undici": "^7.0.0",
    "unique-names-generator": "^4.7.1",
    "unpdf": "^1.4.0",
    "uuid": "^13.0.0",
    "yaml": "^2.7.0",
    "zod": "^4.3.6"
  },
  "publishConfig": {
    "access": "public"
  },
  "gitHead": "cb192f7b21c441e9463d1af2f890c145814baad2"
}
