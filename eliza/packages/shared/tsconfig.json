{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": false,
    "jsx": "react-jsx",
    "skipLibCheck": true,
    "esModuleInterop": false,
    "allowSyntheticDefaultImports": true,
    "strict": false,
    "useUnknownInCatchVariables": false,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "types": ["node", "bun"],
    "baseUrl": ".",
    "paths": {
      "@types/*": ["./src/*"],
      "react": ["../app-core/node_modules/@types/react"],
      "react/jsx-runtime": [
        "../app-core/node_modules/@types/react/jsx-runtime.d.ts"
      ],
      "react-dom": ["../app-core/node_modules/@types/react-dom"]
    }
  },
  "exclude": [
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "../app-core/src/ui/**/*.stories.ts",
    "../app-core/src/ui/**/*.stories.tsx",
    "../app-core/src/ui/**/*.test.ts",
    "../app-core/src/ui/**/*.test.tsx"
  ],
  "include": ["src", "../app-core/src/ui"],
  "references": []
}
