{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "types": ["node", "vite/client"],
    "declaration": false,
    "noEmit": true,
    "baseUrl": "../../",
    "paths": {
      "@elizaos/app-lifeops": ["./apps/app-lifeops/src/index.ts"],
      "@elizaos/app-lifeops/*": ["./apps/app-lifeops/src/*"],
      "@elizaos/plugin-lifeops-browser": [
        "./plugins/plugin-lifeops-browser/src/index.ts"
      ],
      "@elizaos/plugin-lifeops-browser/*": [
        "./plugins/plugin-lifeops-browser/src/*"
      ],
      "@elizaos/app-core": ["./packages/app-core/src/index.ts"],
      "@elizaos/app-core/*": ["./packages/app-core/src/*"],
      "@elizaos/agent": ["./packages/agent/src/index.ts"],
      "@elizaos/agent/*": ["./packages/agent/src/*"],
      "@elizaos/app-companion": ["./apps/app-companion/src/index.ts"],
      "@elizaos/app-companion/*": ["./apps/app-companion/src/*"],
      "@elizaos/shared": ["./packages/shared/src/index.ts"],
      "@elizaos/shared/*": ["./packages/shared/src/*"],
      "@elizaos/core": ["./packages/typescript/src/index.ts"],
      "@elizaos/core/*": ["./packages/typescript/src/*"],
      "@elizaos/*": ["./node_modules/@elizaos/*"]
    }
  },
  "exclude": [
    "src/**/*.stories.ts",
    "src/**/*.stories.tsx",
    "src/**/*.test.ts",
    "src/**/*.test.tsx",
    "../../apps/app-companion/src/**/*.stories.ts",
    "../../apps/app-companion/src/**/*.stories.tsx",
    "../../apps/app-companion/src/**/*.test.ts",
    "../../apps/app-companion/src/**/*.test.tsx"
  ],
  "include": ["src", "../agent/src/external-modules.d.ts", "../../apps/app-companion/src"]
}
