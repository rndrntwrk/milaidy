{
  "name": "@elizaos/app-core",
  "version": "2.0.0-alpha.83",
  "description": "Shared application core for elizaOS white-label agent apps.",
  "type": "module",
  "license": "MIT",
  "homepage": "https://github.com/elizaOS/eliza",
  "repository": {
    "type": "git",
    "url": "https://github.com/elizaOS/eliza.git",
    "directory": "packages/app-core"
  },
  "keywords": [
    "elizaos",
    "app-core",
    "react",
    "white-label",
    "agent-framework"
  ],
  "main": "src/index.ts",
  "scripts": {
    "clean": "rm -rf dist",
    "build": "bun run build:dist",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "build:dist": "rm -rf dist && tsc -p tsconfig.build.json && node ../../scripts/copy-package-assets.mjs packages/app-core src/styles src/i18n/locales && node ../../scripts/prepare-package-dist.mjs packages/app-core --compiled-prefix=packages/app-core/src",
    "pack:dry-run": "cd dist && npm pack --dry-run"
  },
  "exports": {
    ".": "./src/index.ts",
    "./App": "./src/App.tsx",
    "./api": "./src/api/index.ts",
    "./api/client": "./src/api/client.ts",
    "./api/response": "./src/api/response.ts",
    "./api/compat-route-shared": "./src/api/compat-route-shared.ts",
    "./config": "./src/config/index.ts",
    "./config/plugin-auto-enable": "./src/config/plugin-auto-enable.ts",
    "./types": "./src/types/index.ts",
    "./events": "./src/events/index.ts",
    "./i18n": "./src/i18n/index.ts",
    "./navigation": "./src/navigation/index.ts",
    "./hooks": "./src/hooks/index.ts",
    "./bridge": "./src/bridge/index.ts",
    "./bridge/electrobun-rpc": "./src/bridge/electrobun-rpc.ts",
    "./bridge/electrobun-runtime": "./src/bridge/electrobun-runtime.ts",
    "./state": "./src/state/index.ts",
    "./state/internal": "./src/state/internal.ts",
    "./state/persistence": "./src/state/persistence.ts",
    "./state/shell-routing": "./src/state/shell-routing.ts",
    "./components": "./src/components/index.ts",
    "./components/*": "./src/components/*",
    "./components/apps/overlay-app-api": "./src/components/apps/overlay-app-api.ts",
    "./components/apps/overlay-app-registry": "./src/components/apps/overlay-app-registry.ts",
    "./components/character/CharacterEditor": "./src/components/character/CharacterEditor.tsx",
    "./components/character/character-greeting": "./src/components/character/character-greeting.ts",
    "./components/inventory/chainConfig": "./src/components/inventory/chainConfig.ts",
    "./components/inventory/constants": "./src/components/inventory/constants.ts",
    "./components/pages/ChatModalView": "./src/components/pages/ChatModalView.tsx",
    "./components/shared/LanguageDropdown": "./src/components/shared/LanguageDropdown.tsx",
    "./components/shared/ThemeToggle": "./src/components/shared/ThemeToggle.tsx",
    "./utils": "./src/utils/index.ts",
    "./utils/*": "./src/utils/*",
    "./utils/desktop-workspace": "./src/utils/desktop-workspace.ts",
    "./utils/format": "./src/utils/format.ts",
    "./voice": "./src/voice/index.ts",
    "./autonomy": "./src/autonomy/index.ts",
    "./chat": "./src/chat/index.ts",
    "./platform": "./src/platform/index.ts",
    "./platform/native-plugin-entrypoints": "./src/platform/native-plugin-entrypoints.ts",
    "./platform/empty-node-module": "./src/platform/empty-node-module.ts",

    "./onboarding/flow": "./src/onboarding/flow.ts",
    "./onboarding/types": "./src/onboarding/types.ts",
    "./onboarding/connection-flow": "./src/onboarding/connection-flow.ts",
    "./onboarding-config": "./src/onboarding-config.ts",
    "./runtime/eliza": "./src/runtime/eliza.ts",
    "./providers": "./src/providers/index.ts",
    "./actions": "./src/actions/index.ts",
    "./services/steward-credentials": "./src/services/steward-credentials.ts",
    "./services/steward-sidecar": "./src/services/steward-sidecar.ts",
    "./styles/base.css": "./src/styles/base.css",
    "./styles/xterm.css": "./src/styles/xterm.css",
    "./styles/onboarding-game.css": "./src/styles/onboarding-game.css",
    "./styles/styles.css": "./src/styles/styles.css",
    "./shell": "./src/shell/index.ts",
    "./styles/brand-gold.css": "./src/styles/brand-gold.css",
    "./character-catalog": "./src/character-catalog.ts",
    "./test-support/test-helpers": "./src/test-support/test-helpers.ts"
  },
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "dependencies": {
    "@capacitor/core": "8.0.2",
    "@capacitor/haptics": "8.0.0",
    "@capacitor/keyboard": "8.0.0",
    "@capacitor/preferences": "^8.0.1",
    "@elizaos/app-coding": "workspace:*",
    "@elizaos/app-shopify": "workspace:*",
    "@elizaos/app-steward": "workspace:*",
    "@elizaos/app-vincent": "workspace:*",
    "@elizaos/ui": "workspace:*",
    "@elizaos/core": "workspace:*",
    "@elizaos/agent": "workspace:*",
    "@elizaos/plugin-wechat": "github:milady-ai/plugin-wechat",
    "@stwd/sdk": "^0.3.0",
    "lucide-react": "^0.575.0",
    "zod": "^4.3.6",
    "@elizaos/shared": "workspace:*",
    "@xterm/xterm": "^5.5.0",
    "@xterm/addon-fit": "^0.10.0",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.0"
  },
  "publishConfig": {
    "access": "public",
    "directory": "dist"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.182.0",
    "react-test-renderer": "^19.2.4",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  }
}
