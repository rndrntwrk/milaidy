{
  // Root-only (write-build-info, tsdown config). Apps/packages use their own `tsc` via `miladyTypecheckSteps` in scripts/run-repo-checks.mjs.
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["node", "bun"]
  },
  "include": ["scripts/write-build-info.ts", "tsdown.config.ts"],
  "exclude": ["node_modules", "dist"]
}
