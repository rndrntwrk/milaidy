{
  "$schema": "https://biomejs.dev/schemas/2.4.2/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignoreUnknown": true,
    "maxSize": 1048576,
    "includes": [
      "**",
      "!assets",
      "!dist",
      "!apps/app/public",
      "!apps/app/electrobun/build",
      "!**/tsc-out",
      "!**/dist-tsc",
      "!docs/_layouts",
      "!**/.github/contributor-trust.json",
      "!node_modules",
      "!patches",
      "!bun.lock",
      "!bun.lockb",
      "!skills",
      "!Swabble",
      "!vendor",
      "!**/vrms/imported-avatars.json",
      "!collision-report.json",
      "!scripts/type-audit-report.json",
      "!scripts/type-audit-report.md",
      "!scripts/lib/elizaos-core-roles-shim.js"
    ]
  },
  "assist": {
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "recommended": true,
      "correctness": {
        "noUnusedPrivateClassMembers": "warn"
      },
      "style": {
        "noNonNullAssertion": "warn",
        "useSelfClosingElements": "warn"
      },
      "suspicious": {
        "noExplicitAny": "error",
        "noImplicitAnyLet": "warn",
        "useIterableCallbackReturn": "warn",
        "noAssignInExpressions": "warn",
        "useAdjacentOverloadSignatures": "warn"
      },
      "complexity": {
        "noBannedTypes": "warn"
      },
      "performance": {
        "noAccumulatingSpread": "off"
      }
    }
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2
  },
  "css": {
    "parser": {
      "tailwindDirectives": true
    }
  },
  "overrides": [
    {
      "includes": ["**/*.css"],
      "linter": {
        "rules": {
          "suspicious": {
            "noDuplicateProperties": "off"
          }
        }
      }
    },
    {
      "includes": [
        "apps/app/src/main.tsx",
        "eliza/packages/app-core/src/styles/styles.css"
      ],
      "assist": {
        "actions": {
          "source": {
            "organizeImports": "off"
          }
        }
      }
    }
  ]
}
