{
  "name": "@milady/browser-extension-lifeops",
  "version": "0.1.0",
  "private": true,
  "description": "LifeOps browser extension (Chrome MV3 + Safari Web Extension) — per-domain time tracking and agent context feed.",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "build:chrome": "node scripts/build.mjs --target=chrome",
    "build:safari": "node scripts/build.mjs --target=safari",
    "package:chrome": "node scripts/package-chrome.mjs",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/chrome": "^0.0.287",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^5.0.0",
    "jsdom": "^28.1.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "typescript": "^5.9.3",
    "vite": "^7.1.12",
    "vitest": "^4.1.0"
  }
}
