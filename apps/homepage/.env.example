# Vite-exposed env vars for apps/homepage.
# Copy to apps/homepage/.env.local and adjust as needed.
# Only `VITE_*` variables are exposed to the browser bundle.

# Cloud API base URL.
# Default (no override): https://www.elizacloud.ai
# For local backend dev: http://localhost:3000
# Used by apps/homepage/src/lib/runtime-config.ts -> CLOUD_BASE.
VITE_ELIZA_CLOUD_BASE=http://localhost:3000

# Local Eliza agent base URL (for the embedded chat surface).
# Default: http://localhost:2138
# VITE_LOCAL_AGENT_BASE=http://localhost:2138

# User-facing agent UI base domain. Sandbox discovery rewrites
# *.waifu.fun hosts to *.<this domain>.
# Default: milady.ai
# VITE_AGENT_UI_BASE_DOMAIN=milady.ai

# Override the sandbox discovery URL (rarely needed).
# Default: https://sandboxes.waifu.fun/agents
# VITE_SANDBOX_DISCOVERY_URL=https://sandboxes.waifu.fun/agents
