{
  "name": "@miladyai/app",
  "version": "2.0.0-alpha.87",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "design-review": "node --import tsx test/design-review/run-design-review.ts",
    "lint": "bunx @biomejs/biome check src test scripts vite.config.ts vitest.config.ts vitest.e2e.config.ts playwright.ui-smoke.config.ts playwright.ui-packaged.config.ts playwright.electrobun.packaged.config.ts playwright.web-views.config.ts package.json capacitor.config.ts",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --config vitest.config.ts",
    "test:ui": "vitest run --config vitest.config.ts test/app/command-palette.test.tsx test/app/chat-view.test.tsx test/app/conversations-sidebar.test.tsx test/app/events.test.ts test/app/command-registry.test.ts test/app/shell-overlays.test.tsx test/app/shortcuts-overlay.test.tsx test/app/confirm-modal.test.tsx",
    "test:e2e": "node scripts/run-ui-playwright.mjs --config playwright.ui-smoke.config.ts",
    "test:e2e:settings-chat": "node scripts/run-ui-playwright.mjs --config playwright.ui-smoke.config.ts test/ui-smoke/settings-chat-companion.spec.ts",
    "test:e2e:cloud-wallet": "node scripts/run-ui-playwright.mjs --config playwright.ui-smoke.config.ts test/ui-smoke/cloud-wallet-import.spec.ts",
    "test:e2e:packaged": "node scripts/run-ui-playwright.mjs --config playwright.ui-packaged.config.ts test/ui-smoke/packaged-hash.spec.ts",
    "test:watch": "vitest --config vitest.config.ts",
    "plugin:build": "bun scripts/plugin-build.mjs",
    "build": "bun scripts/build.mjs",
    "build:ios": "node ../../eliza/packages/app-core/scripts/run-mobile-build.mjs ios",
    "build:android": "node ../../eliza/packages/app-core/scripts/run-mobile-build.mjs android",
    "ios": "bun run build:ios && capacitor open ios",
    "android": "bun run build:android && capacitor open android",
    "cap:sync": "capacitor sync",
    "cap:sync:ios": "node scripts/ensure-capacitor-platform.mjs ios && capacitor sync ios",
    "cap:sync:android": "node scripts/ensure-capacitor-platform.mjs android && capacitor sync android",
    "cap:open:ios": "capacitor open ios",
    "cap:open:android": "capacitor open android",
    "build:web": "vite build"
  },
  "dependencies": {
    "@elizaos/app-companion": "workspace:*",
    "@elizaos/app-lifeops": "workspace:*",
    "@elizaos/app-shopify": "workspace:*",
    "@elizaos/app-vincent": "workspace:*",
    "@capacitor/android": "8.0.2",
    "@capacitor/app": "8.0.1",
    "@capacitor/core": "8.0.2",
    "@capacitor/ios": "8.0.2",
    "@capacitor/keyboard": "8.0.0",
    "@capacitor/preferences": "8.0.1",
    "@elizaos/app-core": "workspace:*",
    "@elizaos/shared": "workspace:*",
    "@elizaos/capacitor-agent": "workspace:*",
    "@elizaos/capacitor-camera": "workspace:*",
    "@elizaos/capacitor-canvas": "workspace:*",
    "@elizaos/capacitor-desktop": "workspace:*",
    "@elizaos/capacitor-gateway": "workspace:*",
    "@elizaos/capacitor-location": "workspace:*",
    "@elizaos/capacitor-mobile-signals": "workspace:*",
    "@elizaos/capacitor-screencapture": "workspace:*",
    "@elizaos/capacitor-swabble": "workspace:*",
    "@elizaos/capacitor-talkmode": "workspace:*",
    "@elizaos/capacitor-websiteblocker": "workspace:*",
    "@pixiv/three-vrm": "^3.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.182.0"
  },
  "devDependencies": {
    "@capacitor/cli": "8.2.0",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react-swc": "^4.2.1",
    "bun-types": "^1.3.12",
    "jsdom": "^28.1.0",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vitest": "^2.1.9"
  }
}
