{
  "name": "@miladyai/app",
  "version": "2.0.0-alpha.87",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "design-review": "node --import tsx test/design-review/run-design-review.ts",
    "test": "vitest run --config vitest.config.ts",
    "test:ui": "vitest run --config vitest.config.ts test/app/command-palette.test.tsx test/app/chat-view.test.tsx test/app/conversations-sidebar.test.tsx test/app/events.test.ts test/app/command-registry.test.ts test/app/shell-overlays.test.tsx test/app/shortcuts-overlay.test.tsx test/app/confirm-modal.test.tsx",
    "test:watch": "vitest --config vitest.config.ts",
    "plugin:build": "bun scripts/plugin-build.mjs",
    "build": "bun scripts/build.mjs",
    "build:ios": "bun ../../scripts/rt.mjs run build && capacitor sync ios",
    "build:android": "bun ../../scripts/rt.mjs run build && capacitor sync android",
    "ios": "bun ../../scripts/rt.mjs run build:ios && capacitor open ios",
    "android": "bun ../../scripts/rt.mjs run build:android && capacitor open android",
    "cap:sync": "capacitor sync",
    "cap:sync:ios": "capacitor sync ios",
    "cap:sync:android": "capacitor sync android",
    "cap:open:ios": "capacitor open ios",
    "cap:open:android": "capacitor open android",
    "build:web": "vite build"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.2",
    "@capacitor/app": "^8.0.1",
    "@capacitor/core": "8.0.2",
    "@capacitor/haptics": "8.0.0",
    "@capacitor/ios": "^8.0.2",
    "@capacitor/keyboard": "8.0.0",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@miladyai/app-core": "workspace:*",
    "@miladyai/capacitor-agent": "workspace:*",
    "@miladyai/capacitor-camera": "workspace:*",
    "@miladyai/capacitor-canvas": "workspace:*",
    "@miladyai/capacitor-desktop": "workspace:*",
    "@miladyai/capacitor-gateway": "workspace:*",
    "@miladyai/capacitor-location": "workspace:*",
    "@miladyai/capacitor-screencapture": "workspace:*",
    "@miladyai/capacitor-swabble": "workspace:*",
    "@miladyai/capacitor-talkmode": "workspace:*",
    "@miladyai/ui": "workspace:*",
    "@noble/curves": "^2.0.1",
    "@pixiv/three-vrm": "^3.4.5",
    "@sparkjsdev/spark": "^0.1.10",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.182.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@capacitor/cli": "8.0.2",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.182.0",
    "@vitejs/plugin-react-swc": "^4.2.1",
    "jsdom": "^28.1.0",
    "react-test-renderer": "^19.2.4",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vitest": "^2.1.9"
  }
}
