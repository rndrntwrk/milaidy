{
  "name": "@milady/app",
  "version": "2.0.0-alpha.75",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "test": "vitest run --config vitest.config.ts",
    "test:ui": "vitest run --config vitest.config.ts test/app/command-palette test/app/chat-view test/app/conversations-sidebar test/app/events test/app/command-registry test/app/shell-overlays test/app/shortcuts-overlay test/app/confirm-modal",
    "test:watch": "vitest --config vitest.config.ts",
    "plugin:build": "for d in gateway swabble camera screencapture canvas desktop location talkmode agent; do echo \"[plugin:$d] building...\" && (cd plugins/$d && ../../../../scripts/rt.sh run build) || exit 1; done",
    "build": "(cd ../.. && scripts/rt.sh run install:build) && ../../scripts/rt.sh run plugin:build && ../../scripts/rt.sh install --ignore-scripts && vite build",
    "build:ios": "../../scripts/rt.sh run build && capacitor sync ios",
    "build:android": "../../scripts/rt.sh run build && capacitor sync android",
    "ios": "../../scripts/rt.sh run build:ios && capacitor open ios",
    "android": "../../scripts/rt.sh run build:android && capacitor open android",
    "cap:sync": "capacitor sync",
    "cap:sync:ios": "capacitor sync ios",
    "cap:sync:android": "capacitor sync android",
    "cap:open:ios": "capacitor open ios",
    "cap:open:android": "capacitor open android"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.2",
    "@capacitor/app": "^8.0.1",
    "@capacitor/core": "8.0.2",
    "@capacitor/haptics": "8.0.0",
    "@capacitor/ios": "^8.0.2",
    "@capacitor/keyboard": "8.0.0",
    "@capacitor/preferences": "^8.0.1",
    "@capacitor/status-bar": "^8.0.1",
    "@milady/capacitor-agent": "workspace:*",
    "@milady/capacitor-camera": "workspace:*",
    "@milady/capacitor-canvas": "workspace:*",
    "@milady/capacitor-desktop": "workspace:*",
    "@milady/capacitor-gateway": "workspace:*",
    "@milady/capacitor-location": "workspace:*",
    "@milady/capacitor-screencapture": "workspace:*",
    "@milady/capacitor-swabble": "workspace:*",
    "@milady/capacitor-talkmode": "workspace:*",
    "@lifo-sh/core": "0.4.4",
    "@lifo-sh/ui": "0.4.2",
    "@noble/curves": "^2.0.1",
    "@pixiv/three-vrm": "^3.4.5",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "three": "^0.182.0",
    "@xterm/addon-fit": "^0.10.0",
    "@xterm/xterm": "^5.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@capacitor/cli": "8.0.2",
    "@playwright/test": "^1.58.2",
    "@tailwindcss/vite": "^4.1.18",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/three": "^0.182.0",
    "@vitejs/plugin-react": "^5.1.3",
    "jsdom": "^28.1.0",
    "react-test-renderer": "^19.2.4",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vitest": "^2.1.9"
  }
}
