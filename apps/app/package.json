{
  "name": "@milady/app",
  "version": "2.0.0-alpha.82",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "preview": "vite preview",
    "test": "vitest run --config vitest.config.ts",
    "test:ui": "vitest run --config vitest.config.ts test/app/command-palette.test.tsx test/app/chat-view.test.tsx test/app/conversations-sidebar.test.tsx test/app/events.test.ts test/app/command-registry.test.ts test/app/shell-overlays.test.tsx test/app/shortcuts-overlay.test.tsx test/app/confirm-modal.test.tsx",
    "test:watch": "vitest --config vitest.config.ts",
    "storybook": "storybook dev -p 6007",
    "build-storybook": "storybook build",
    "plugin:build": "node scripts/plugin-build.mjs",
    "build": "node scripts/build.mjs",
    "build:ios": "node ../../scripts/rt.mjs run build && capacitor sync ios",
    "build:android": "node ../../scripts/rt.mjs run build && capacitor sync android",
    "ios": "node ../../scripts/rt.mjs run build:ios && capacitor open ios",
    "android": "node ../../scripts/rt.mjs run build:android && capacitor open android",
    "cap:sync": "capacitor sync",
    "cap:sync:ios": "capacitor sync ios",
    "cap:sync:android": "capacitor sync android",
    "cap:open:ios": "capacitor open ios",
    "cap:open:android": "capacitor open android",
    "build:web": "vite build"
  },
  "dependencies": {
    "@capacitor/android": "^8.0.2",
