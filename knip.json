{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "ignore": [
    "**/*.d.ts",
    "**/dist/**",
    "**/build/**",
    "**/.vite/**",
    "node_modules/**",
    "test/contracts/lib/**"
  ],
  "ignoreDependencies": ["typescript"],
  "workspaces": {
    ".": {
      "entry": [
        "src/entry.ts",
        "milady.mjs",
        "scripts/*.js",
        "scripts/*.mjs",
        "scripts/*.ts",
        "scripts/rt.sh",
        "tsdown.electrobun.config.ts",
        "tsdown.electrobun.config.test.ts",
        "vitest.live.config.ts"
      ],
      "project": ["src/**/*.{ts,tsx}", "scripts/**/*.{ts,mjs,js}"]
    },
    "packages/app-core": {
      "entry": ["src/index.ts", "src/runtime/dev-server.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/ui": {
      "entry": [
        "src/index.ts",
        "src/components/ui/*.tsx",
        "src/hooks/**/*.ts",
        "src/lib/*.ts",
        "src/stories/*.{ts,tsx}"
      ],
      "project": ["src/**/*.{ts,tsx}"],
      "includeEntryExports": true
    },
    "packages/agent": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.{ts,tsx}"],
      "ignore": ["test/**"]
    },
    "packages/shared": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/types": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/vrm-utils": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/plugin-wechat": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "apps/app": {
      "entry": ["src/main.tsx", "src/stubs/*.ts", "vite.config.ts"],
      "project": ["src/**/*.{ts,tsx}"],
      "ignore": ["electrobun/**", "plugins/**"]
    },
    "apps/app/electrobun": {
      "entry": [
        "src/index.ts",
        "src/native/agent.ts",
        "src/bridge/electrobun-preload.ts"
      ],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "apps/home": {
      "entry": ["src/main.tsx"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "apps/web": {
      "entry": ["src/main.tsx"],
      "project": ["src/**/*.{ts,tsx}"]
    }
  }
}
