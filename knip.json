{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "entry": [
    "src/entry.ts",
    "milady.mjs",
    "scripts/*.mjs",
    "scripts/*.ts",
    "scripts/rt.sh"
  ],
  "project": [
    "src/**/*.{ts,tsx}",
    "scripts/**/*.{ts,mjs,js}"
  ],
  "ignore": [
    "**/*.d.ts",
    "**/dist/**",
    "**/build/**",
    "**/.vite/**",
    "node_modules/**"
  ],
  "ignoreDependencies": [
    "typescript"
  ],
  "workspaces": {
    "packages/app-core": {
      "entry": [
        "src/index.ts",
        "src/runtime/dev-server.ts"
      ],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/ui": {
      "entry": [
        "src/index.ts",
        "src/components/ui/*.tsx",
        "src/hooks/**/*.ts",
        "src/lib/*.ts",
        "src/stories/*.{ts,tsx}"
      ],
      "project": ["src/**/*.{ts,tsx}"],
      "includeEntryExports": true
    },
    "packages/agent": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.{ts,tsx}"],
      "ignore": ["test/**"]
    },
    "packages/shared": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/vrm-utils": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "packages/plugin-wechat": {
      "entry": ["src/index.ts"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "apps/app": {
      "entry": ["src/main.tsx", "vite.config.ts"],
      "project": ["src/**/*.{ts,tsx}"],
      "ignore": [
        "electrobun/**",
        "plugins/**"
      ]
    },
    "apps/app/electrobun": {
      "entry": [
        "src/native/main.ts",
        "src/native/agent.ts",
        "src/native/preload.ts"
      ],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "apps/home": {
      "entry": ["src/main.tsx"],
      "project": ["src/**/*.{ts,tsx}"]
    },
    "apps/homepage": {
      "entry": ["src/main.tsx", "src/entry-client.tsx", "src/entry-server.tsx"],
      "project": ["src/**/*.{ts,tsx}"]
    }
  }
}
