# MiladyOS init script.
#
# Lands at /product/etc/init/init.milady.rc and is loaded by init at
# boot. Use this for boot-time properties, service definitions, and
# one-shot grants that the privapp-permissions whitelist + default-
# permissions XML cannot express on their own.
#
# Reference: https://source.android.com/docs/core/init/init-language

on early-init
    setprop ro.miladyos.boot_phase early-init

on init
    setprop ro.miladyos.boot_phase init

on post-fs-data
    # Ensure the Milady process has writable scratch directory regardless
    # of which volume the user-data partition lands on. mkdir is idempotent.
    mkdir /data/milady 0770 system system

on boot
    setprop ro.miladyos.boot_phase boot

on property:sys.boot_completed=1
    setprop ro.miladyos.boot_phase completed
    # GET_USAGE_STATS appop is granted programmatically by MiladyBootReceiver.
    # Other appops that the privileged manifest declares should be flipped
    # here once their service paths land — keep this block as the single
    # known location for first-boot appop grants so audits stay simple.
    exec - root root -- /system/bin/sh -c "appops set --user 0 com.miladyai.milady SYSTEM_ALERT_WINDOW allow"
    exec - root root -- /system/bin/sh -c "appops set --user 0 com.miladyai.milady GET_USAGE_STATS allow"
