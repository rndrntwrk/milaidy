# syntax=docker/dockerfile:1.7
# elizaOS Agent — CI Docker Image
# Pre-built artifacts come from GHA (bun install + tsdown + vite build done before docker)
ARG NODE_VERSION=22
ARG BUN_VERSION=1.3.10
ARG ESBUILD_VERSION=0.28.0
ARG APP_ENTRYPOINT=app.mjs
ARG APP_CMD_START=""
ARG APP_PORT=2138
ARG APP_API_BIND=127.0.0.1
ARG OCI_SOURCE=""
ARG OCI_TITLE="elizaOS Agent"
ARG OCI_DESCRIPTION="elizaOS agent runtime"
ARG OCI_LICENSES="MIT"
ARG VERSION=""
ARG VERSION_CLEAN=""
ARG REVISION=""

FROM node:${NODE_VERSION}-slim AS pruner
WORKDIR /app
COPY . .

# ===== Replace workspace symlinks with actual compiled packages =====
# Bun workspace symlinks break in Docker. Delete the symlinks entirely
# and replace with the actual package contents + CI-compiled dist/.
RUN set -x; \
    # @elizaos/core: delete symlink, copy package + compiled dist
    rm -rf node_modules/@elizaos/core; \
    mkdir -p node_modules/@elizaos/core; \
    cp eliza/packages/typescript/package.json node_modules/@elizaos/core/; \
    cp -a eliza/packages/typescript/dist node_modules/@elizaos/core/dist 2>/dev/null || true; \
    # NOTE: Do NOT copy src/ - tsx will prefer raw .ts over compiled dist/
    # cp -a eliza/packages/typescript/src node_modules/@elizaos/core/src 2>/dev/null || true; \
    ls node_modules/@elizaos/core/dist/node/index.node.js 2>/dev/null && echo "@elizaos/core dist OK" || echo "WARN: core dist/node missing"; \
    # @elizaos/agent: delete symlink, copy package + compiled dist
    rm -rf node_modules/@elizaos/agent; \
    mkdir -p node_modules/@elizaos/agent; \
    cp eliza/packages/agent/package.json node_modules/@elizaos/agent/; \
    cp -a eliza/packages/agent/dist node_modules/@elizaos/agent/dist 2>/dev/null || true; \
    # NOTE: Do NOT copy src/ - tsx will prefer raw .ts over compiled dist/
    # cp -a eliza/packages/agent/src node_modules/@elizaos/agent/src 2>/dev/null || true; \
    ls node_modules/@elizaos/agent/dist/ 2>/dev/null | head -3 && echo "@elizaos/agent dist OK" || echo "WARN: agent dist missing"; \
    # @elizaos/shared: DON'T replace — the npm version or resolved workspace symlink works.
    # Workspace package.json exports point to ./src/*.ts (tsx handles this).
    # Replacing with dist-only breaks resolution since exports don't match dist layout.
    # @elizaos/app-companion: copy real package contents instead of relying on a workspace symlink
    # The runtime executes agent/src under tsx, and static imports like
    # @elizaos/app-companion/plugin must resolve through node_modules at runtime.
    rm -rf node_modules/@elizaos/app-companion; \
    mkdir -p node_modules/@elizaos/app-companion; \
    cp eliza/apps/app-companion/package.json node_modules/@elizaos/app-companion/; \
    cp -a eliza/apps/app-companion/src node_modules/@elizaos/app-companion/src 2>/dev/null || true; \
    cp eliza/apps/app-companion/assets.json node_modules/@elizaos/app-companion/assets.json 2>/dev/null || true; \
    ls node_modules/@elizaos/app-companion/src/plugin.ts 2>/dev/null && echo "@elizaos/app-companion src OK" || echo "WARN: app-companion src missing"; \
    # @elizaos/app-lifeops: runtime statically imports /plugin, so ship real package contents
    rm -rf node_modules/@elizaos/app-lifeops; \
    mkdir -p node_modules/@elizaos/app-lifeops; \
    cp eliza/apps/app-lifeops/package.json node_modules/@elizaos/app-lifeops/; \
    cp -a eliza/apps/app-lifeops/src node_modules/@elizaos/app-lifeops/src 2>/dev/null || true; \
    ls node_modules/@elizaos/app-lifeops/src/plugin.ts 2>/dev/null && echo "@elizaos/app-lifeops src OK" || echo "WARN: app-lifeops src missing"
# Link any remaining missing workspace app packages to node_modules
RUN for app_dir in eliza/apps/app-coding eliza/apps/app-shopify; do \
      if [ -d "$app_dir" ]; then \
        PKG_NAME=$(node -p "require('./${app_dir}/package.json').name" 2>/dev/null); \
        if [ -n "$PKG_NAME" ] && [ ! -e "node_modules/$PKG_NAME" ]; then \
          mkdir -p "node_modules/$(dirname $PKG_NAME)"; \
          ln -s "../../$app_dir" "node_modules/$PKG_NAME"; \
          echo "Linked: $PKG_NAME -> $app_dir"; \
        fi; \
      fi; \
    done
# ===== End symlink replacement =====

# Delete raw TypeScript source from eliza workspace packages.
# tsx prefers .ts over compiled .js, causing cascading dep resolution failures.
# Only dist/ is needed at runtime.
# Only remove @elizaos/core src (the one that causes @noble/ciphers import failures).
# Keep agent and shared src because tsdown dist has hardcoded .ts import paths into them.
RUN rm -rf eliza/packages/typescript/src 2>/dev/null || true

# Fix dist layout: package.json says dist/index.node.js but build creates dist/node/index.node.js
RUN CORE_DIR="node_modules/@elizaos/core"; \
    if [ -f "$CORE_DIR/dist/node/index.node.js" ] && [ ! -f "$CORE_DIR/dist/index.node.js" ]; then \
      ln -s node/index.node.js "$CORE_DIR/dist/index.node.js"; \
      echo "Linked dist/index.node.js -> dist/node/index.node.js"; \
    fi; \
    if [ -f "$CORE_DIR/dist/browser/index.browser.js" ] && [ ! -f "$CORE_DIR/dist/index.browser.js" ]; then \
      ln -s browser/index.browser.js "$CORE_DIR/dist/index.browser.js"; \
    fi

# Hoist missing deps from workspace packages to top-level node_modules
# tsx resolves raw .ts source which imports packages not hoisted by bun
RUN for pkg_dir in eliza/packages/typescript eliza/packages/shared eliza/packages/agent eliza/apps/app-companion eliza/apps/app-lifeops; do \
      if [ -d "$pkg_dir/node_modules" ]; then \
        for dep in $(ls "$pkg_dir/node_modules/" 2>/dev/null | grep -v '^\.'); do \
          if [ ! -e "node_modules/$dep" ] && [ -d "$pkg_dir/node_modules/$dep" ]; then \
            cp -a "$pkg_dir/node_modules/$dep" "node_modules/$dep"; \
            echo "Hoisted: $dep"; \
          fi; \
        done; \
        for scope in $(ls "$pkg_dir/node_modules/@"* 2>/dev/null -d | xargs -I{} basename {}); do \
          if [ -d "$pkg_dir/node_modules/@$scope" ]; then \
            mkdir -p "node_modules/@$scope"; \
            for dep in $(ls "$pkg_dir/node_modules/@$scope/" 2>/dev/null); do \
              if [ ! -e "node_modules/@$scope/$dep" ]; then \
                cp -a "$pkg_dir/node_modules/@$scope/$dep" "node_modules/@$scope/$dep"; \
                echo "Hoisted: @$scope/$dep"; \
              fi; \
            done; \
          fi; \
        done; \
      fi; \
    done

# Ensure workspace-declared plugins with empty dirs are installed from npm.
# These are declared as workspace:* in bun.lock but the plugin dirs are empty/uncommitted.
# node:slim has no curl, so use Node's built-in https module for tarball extraction.
# Uses Dockerfile heredoc (syntax 1.4+) to avoid Docker misreading JS keywords as instructions.
RUN node - <<'__NODESCRIPT__'
const https = require('https');
const fs = require('fs');
const { execSync } = require('child_process');
function installPkg(name, cb) {
  const pkgDir = 'node_modules/' + name;
  if (fs.existsSync(pkgDir + '/package.json')) { console.log('present: ' + name); return cb && cb(); }
  const url = execSync('npm view ' + name + ' dist.tarball 2>/dev/null', {encoding:'utf8'}).trim();
  if (!url) { console.log('WARN: no tarball for ' + name); return cb && cb(); }
  const tmp = '/tmp/pkg_' + name.replace(/[^a-z0-9]/gi,'_');
  const tgz = tmp + '.tgz';
  https.get(url, res => {
    const chunks = [];
    res.on('data', c => chunks.push(c));
    res.on('end', () => {
      try {
        fs.writeFileSync(tgz, Buffer.concat(chunks));
        fs.mkdirSync(tmp, {recursive:true});
        execSync('tar xz -C ' + tmp + ' -f ' + tgz);
        const scope = name.startsWith('@') ? name.split('/')[0] : null;
        if (scope) fs.mkdirSync('node_modules/' + scope, {recursive:true});
        execSync('rm -rf ' + pkgDir);
        execSync('mv ' + tmp + '/package ' + pkgDir);
        const v = JSON.parse(fs.readFileSync(pkgDir + '/package.json','utf8')).version;
        console.log('+ ' + name + '@' + v);
      } catch(e) { console.error('WARN ' + name + ': ' + e.message); }
      cb && cb();
    });
  }).on('error', e => { console.error('WARN ' + name + ': ' + e.message); cb && cb(); });
}
const missing = [
  '@elizaos/plugin-agent-skills',
  '@elizaos/plugin-anthropic',
  '@elizaos/plugin-local-embedding',
  '@elizaos/plugin-pdf',
  '@elizaos/plugin-sql',
];
(function next(i) { if (i >= missing.length) return; installPkg(missing[i], () => next(i+1)); })(0);
__NODESCRIPT__

# Patch plugin-agent-skills getCatalogStats crash (alpha.11 vs alpha.66 interface mismatch)
RUN sed -i 's/const stats = service.getCatalogStats();/const stats = typeof service.getCatalogStats === "function" ? service.getCatalogStats() : { loaded: 0, total: 0, storageType: "unknown" };/g' node_modules/@elizaos/plugin-agent-skills/dist/index.js 2>/dev/null || true
ARG VERSION_CLEAN

# Patch autonomous version
RUN if [ -n "${VERSION_CLEAN}" ]; then \
  node -e " \
  const fs = require('fs'); \
  const v = '${VERSION_CLEAN}'; \
  try { \
  const p = JSON.parse(fs.readFileSync('node_modules/@elizaos/agent/package.json', 'utf8')); \
  p.version = v; \
  fs.writeFileSync('node_modules/@elizaos/agent/package.json', JSON.stringify(p, null, 2)); \
  console.log('Patched autonomous to', v); \
  } catch(e) { console.log('skip:', e.message); } \
  "; \
  fi

# Remove unbuilt orchestrator (desktop-only, crashes tsx if dist/ missing)
RUN rm -rf \
  node_modules/@elizaos/plugin-agent-orchestrator \
  node_modules/.bun/@elizaos+plugin-agent-orchestrator@* \
  eliza/packages/agent/node_modules/@elizaos/plugin-agent-orchestrator \
  plugins/plugin-agent-orchestrator \
  2>/dev/null || true

# Safe pruning only (GPU binaries + obvious dead weight)
RUN rm -rf \
  node_modules/.bun/@node-llama-cpp+linux-x64-cuda-ext@* \
  node_modules/.bun/@node-llama-cpp+linux-x64-cuda@* \
  node_modules/.bun/@node-llama-cpp+linux-x64-vulkan@* \
  node_modules/.bun/@node-llama-cpp+linux-arm64@* \
  node_modules/.bun/@node-llama-cpp+linux-armv7l@* \
  node_modules/@storybook \
  node_modules/storybook \
  apps/app/public \
  2>/dev/null || true

# Remove source maps and test dirs
RUN find node_modules -name '*.map' -delete 2>/dev/null; \
  find node_modules -type d -name '__tests__' -exec rm -rf {} + 2>/dev/null; \
  find node_modules -type d -name 'test' -maxdepth 3 -exec rm -rf {} + 2>/dev/null; \
  true

FROM node:${NODE_VERSION}-slim
ARG BUN_VERSION
ARG ESBUILD_VERSION
ARG APP_ENTRYPOINT
ARG APP_CMD_START
ARG APP_PORT
ARG APP_API_BIND
ARG OCI_SOURCE
ARG OCI_TITLE
ARG OCI_DESCRIPTION
ARG OCI_LICENSES
ARG VERSION
ARG VERSION_CLEAN
ARG REVISION
LABEL org.opencontainers.image.title="${OCI_TITLE}" \
      org.opencontainers.image.description="${OCI_DESCRIPTION}" \
      org.opencontainers.image.source="${OCI_SOURCE}" \
      org.opencontainers.image.url="${OCI_SOURCE}" \
      org.opencontainers.image.version="${VERSION_CLEAN}" \
      org.opencontainers.image.revision="${REVISION}" \
      org.opencontainers.image.licenses="${OCI_LICENSES}"
RUN apt-get update && apt-get install -y --no-install-recommends ca-certificates curl ffmpeg libopus-dev \
  && rm -rf /var/lib/apt/lists/*
WORKDIR /app
COPY --from=pruner /app /app

# NOTE: Do NOT install esbuild globally. tsx bundles its own esbuild.
# A global esbuild binary causes a recursive fork bomb (8000+ processes)
# when tsx's loader spawns esbuild service processes.

ENV NODE_ENV=production
ENV APP_ENTRYPOINT=${APP_ENTRYPOINT}
ENV APP_CMD_START=${APP_CMD_START}
ENV APP_PORT=${APP_PORT}
ENV APP_API_BIND=${APP_API_BIND}
ENV ELIZA_PORT=${APP_PORT}
ENV ELIZA_API_BIND=${APP_API_BIND}
# Bake the cloud image version so the version-resolver picks it up at runtime
# (takes priority over package.json patching which can be fragile)
ENV ELIZA_BUNDLED_VERSION=${VERSION_CLEAN}
ENV ELIZA_ALLOWED_HOSTS=*
EXPOSE ${APP_PORT}

HEALTHCHECK --interval=30s --timeout=10s --start-period=120s --retries=3 \
  CMD sh -lc 'port="${PORT:-${APP_PORT:-${ELIZA_PORT:-2138}}}"; code="$(curl -s -o /dev/null -w "%{http_code}" "http://127.0.0.1:${port}/api/health")" && [ "$code" = "200" -o "$code" = "401" ]'

ENTRYPOINT ["sh", "./eliza/packages/app-core/scripts/docker-entrypoint.sh"]
CMD ["sh", "-lc", "exec ${APP_CMD_START:-node --import ./node_modules/tsx/dist/loader.mjs ${APP_ENTRYPOINT} start}"]
