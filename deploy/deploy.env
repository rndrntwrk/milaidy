# Milady deployment overrides for the generic app-core deploy toolkit.
# Values not listed here fall back to eliza/packages/app-core/deploy/deploy.defaults.env.

APP_NAME=milady
APP_ENTRYPOINT=milady.mjs
APP_CMD_START="node --import ./node_modules/tsx/dist/loader.mjs milady.mjs start"
APP_IMAGE=milady/agent
APP_REGISTRY=ghcr.io/milady-ai/milady
APP_PORT=2138
APP_GATEWAY_PORT=18789
APP_BRIDGE_PORT=18790
APP_STATE_DIR=~/.milady
APP_CONFIG_DIR=~/.milady
APP_DB_NAME=milady

OCI_SOURCE=https://github.com/milady-ai/milady
OCI_TITLE="Milady Agent"
OCI_DESCRIPTION="Milady agent runtime and application shell"

CF_WORKER_NAME=milady-eliza-cloud-proxy
CF_ALLOWED_ORIGINS=https://app.milady.ai,https://milady.ai,http://localhost:5173
CF_PROXY_PATH_PREFIXES=/api/auth/cli-session,/api/compat/,/api/v1/milady/launch-sessions/
