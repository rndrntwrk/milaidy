#!/usr/bin/env bash
#
# Pre-push hook: Prevents direct pushes to the main branch.
# All changes to main must go through a pull request.
#

PROTECTED_BRANCHES=("main")

repo_root=$(git rev-parse --show-toplevel 2>/dev/null || pwd)

current_branch=$(git symbolic-ref HEAD 2>/dev/null | sed 's|refs/heads/||')

# Read the push info from stdin
while read local_ref local_sha remote_ref remote_sha; do
  remote_branch=$(echo "$remote_ref" | sed 's|refs/heads/||')

  for protected in "${PROTECTED_BRANCHES[@]}"; do
    if [ "$remote_branch" = "$protected" ]; then
      echo ""
      echo "🚫  Push to '$protected' branch is not allowed."
      echo "    Please create a pull request instead."
      echo ""
      exit 1
    fi
  done
done

if [ "${MILADY_PREPUSH_FIVE55:-0}" = "1" ]; then
  echo ""
  echo "🔎  Running five55 local pipeline gate (MILADY_PREPUSH_FIVE55=1)..."
  echo ""
  if [ -x "$repo_root/scripts/five55-local-pipeline.sh" ]; then
    (cd "$repo_root" && bash scripts/five55-local-pipeline.sh)
  else
    echo "[pre-push] scripts/five55-local-pipeline.sh not found or not executable" >&2
    exit 1
  fi
fi

exit 0
