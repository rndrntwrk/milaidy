{
  "compilerOptions": {
    "jsx": "react-jsx",
    "allowImportingTsExtensions": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "experimentalDecorators": true,
    "forceConsistentCasingInFileNames": true,
    "lib": ["DOM", "DOM.Iterable", "ES2023", "ScriptHost"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noEmit": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true,
    "target": "es2023",
    "useDefineForClassFields": false,
    "baseUrl": ".",
    "paths": {
      "@miladyai/plugin-selfcontrol": [
        "./packages/plugin-selfcontrol/src/index.ts"
      ],
      "@miladyai/plugin-selfcontrol/*": ["./packages/plugin-selfcontrol/src/*"],
      "@miladyai/ui": ["./packages/ui/src/index.ts"],
      "@miladyai/ui/*": ["./packages/ui/src/*"],
      "@miladyai/agent/*": ["./packages/agent/src/*"],
      "@miladyai/shared": ["./packages/shared/src/index.ts"],
      "@miladyai/shared/*": ["./packages/shared/src/*"],
      "@elizaos/core": [
        "./eliza/packages/typescript/src/index.ts"
      ],
      "@elizaos/core/*": ["./eliza/packages/typescript/src/*"]
    }
  },
  "include": [
    "packages/app-core/src/**/*",
    "packages/agent/src/external-modules.d.ts"
  ],
  "exclude": [
    "node_modules",
    "node_modules/.bun",
    "dist",
    "eliza",
    "plugins",
    "packages/app-core/src/**/*.test.ts",
    "packages/app-core/src/**/*.test.tsx",
    "packages/app-core/src/**/test-helpers.ts",
    "packages/app-core/src/services/training-service.ts"
  ]
}
