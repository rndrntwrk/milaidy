    "build:contracts": "cd test/contracts && forge build --skip Harness",
    "build:desktop": "node scripts/desktop-build.mjs build --variant=base --stage-macos-release-app",
    "desktop:preflight": "node scripts/desktop-build.mjs preflight --variant=base",
    "build:preload": "cd apps/app/electrobun && bun run build:preload",
