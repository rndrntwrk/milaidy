{
  "name": "miladyai",
  "version": "2.0.0-alpha.116",
  "description": "Cute agents for the acceleration",
  "homepage": "https://github.com/milady-ai/milady",
  "author": {
    "name": "Milady AI",
    "email": "hi@milady.ai"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/milady-ai/milady.git"
  },
  "license": "MIT",
  "files": [
    "dist",
    "milady.mjs",
    "apps/app/dist",
    "scripts/rt.sh",
    "scripts/run-node.mjs",
    "scripts/init-submodules.mjs",
    "scripts/setup-eliza-workspace.mjs",
    "scripts/run-repo-setup.mjs",
    "scripts/ensure-skills.mjs",
    "skills",
    "scripts/ensure-avatars.mjs",
    "scripts/link-browser-server.mjs",
    "scripts/ensure-vision-deps.mjs"
  ],
  "bundleDependencies": [
    "@elizaos/plugin-agent-orchestrator"
  ],
  "workspaces": [
    "apps/*",
    "apps/*/plugins/*",
    "apps/app/electrobun",
    "packages/crypto-browserify",
    "packages/app-core",
    "packages/ui",
    "packages/vrm-utils",
    "packages/shared",
    "packages/agent",
    "deploy/cloud-agent-template"
  ],
  "type": "module",
  "main": "build/packages/app-core/src/index.js",
  "bin": {
    "milady": "milady.mjs",
    "milady.ai": "milady.mjs",
    "milady-ai": "milady.mjs",
    "miladyai": "milady.mjs"
  },
  "exports": {
    ".": "./dist/index.js",
    "./cli-entry": "./milady.mjs",
    "./eliza": "./dist/runtime/eliza.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "audit:deps": "bun audit",
    "audit:deps:release": "bun audit --audit-level=moderate",
    "benchmark:preflight": "node scripts/benchmark-preflight.mjs",
    "benchmark:server": "node --import tsx packages/app-core/src/benchmark/server.ts",
    "benchmark:normalize-capture": "node --import tsx scripts/normalize-parallax-capture.ts",
    "benchmark": "bun run benchmarks/run-benchmarks.ts",
    "benchmark:research": "bun run benchmarks/run-benchmarks.ts --type research",
    "benchmark:coding": "bun run benchmarks/run-benchmarks.ts --type coding",
    "benchmark:evaluate": "python3 benchmarks/evaluate.py benchmarks/results/latest/",
    "benchmark:dry-run": "bun run benchmarks/run-benchmarks.ts --dry-run",
    "build": "node scripts/run-production-build.mjs",
    "build:node": "node scripts/run-production-build.mjs",
    "build:android": "cd apps/app && bun scripts/build.mjs && capacitor sync android",
    "build:contracts": "cd test/contracts && forge build --skip Harness",
    "build:desktop": "node scripts/desktop-build.mjs build --variant=base --stage-macos-release-app",
    "desktop:preflight": "node scripts/desktop-build.mjs preflight --variant=base",
    "build:preload": "cd apps/app/electrobun && bun run build:preload",
    "build:home": "cd apps/home && bun run build",
    "build:home:desktop": "node scripts/desktop-build.mjs build --app=home --variant=base --stage-macos-release-app",
    "build:web": "node scripts/write-homepage-release-data.mjs && cd apps/web && bun run build",
    "build:homepage": "bun run build:web",
    "cdn:validate": "node scripts/validate-cdn-assets.mjs",
    "cdn:manifest": "node scripts/generate-static-asset-manifest.mjs",
    "build:ios": "cd apps/app && bun scripts/build.mjs && capacitor sync ios",
    "clean": "node scripts/clean-repo.mjs",
    "clean:deep": "node scripts/clean-repo.mjs --deep",
    "check": "scripts/rt.sh run typecheck && scripts/rt.sh run lint",
    "knip": "bunx knip",
    "knip:fix": "bunx knip --fix",
    "find-dupes": "node scripts/find-duplicate-components.mjs",
    "db:check": "bunx vitest run packages/app-core/src/api/database.security.test.ts packages/app-core/src/api/database.readonly-query-guard.test.ts && bunx vitest run --config vitest.e2e.config.ts packages/agent/test/database-api.e2e.test.ts",
    "dev": "scripts/rt.sh scripts/dev-ui.mjs --name=milady",
    "dev:ui": "scripts/rt.sh scripts/dev-ui.mjs --name=milady --ui-only",
    "dev:desktop": "bun scripts/dev-platform.mjs",
    "dev:desktop:watch": "MILADY_DESKTOP_VITE_WATCH=1 bun scripts/dev-platform.mjs",
    "dev:android": "cd apps/app && bun scripts/build.mjs && capacitor sync android && capacitor open android",
    "dev:home": "scripts/rt.sh scripts/dev-ui.mjs --name=milady --app=home",
    "dev:home:ui": "scripts/rt.sh scripts/dev-ui.mjs --name=milady --app=home --ui-only",
    "dev:web": "cd apps/web && bun run dev",
    "dev:ios": "cd apps/app && bun scripts/build.mjs && capacitor sync ios && capacitor open ios",
    "docs:bin": "scripts/rt.sh scripts/docs-list.js --build-bin",
    "docs:build": "cd docs && bun exec mint broken-links",
    "docs:dev": "cd docs && mint dev",
    "docs:list": "scripts/rt.sh scripts/docs-list.js",
    "format": "bunx @biomejs/biome format packages/app-core/src scripts apps",
    "format:fix": "bunx @biomejs/biome format --write packages/app-core/src scripts apps",
    "lint": "node scripts/run-biome-check.mjs",
    "lint:fix": "node scripts/run-biome-check.mjs --write",
    "generate:plugins": "bun scripts/generate-plugin-index.js",
    "milady": "bun scripts/run-node.mjs",
    "postinstall": "node scripts/run-repo-setup.mjs",
    "pre-review:local": "bun scripts/pre-review-local.mjs",
    "prepack": "scripts/rt.sh run build",
    "publish:plugins:next": "cd plugins && bun run publish:next",
    "release:check": "node --import tsx scripts/release-check.ts",
    "setup:eliza-workspace": "node scripts/setup-eliza-workspace.mjs",
    "smoke:desktop": "bun run test:desktop:packaged",
    "desktop:stack-status": "node scripts/desktop-stack-status.mjs",
    "smoke:api-status": "node scripts/smoke-api-status.mjs",
    "smoke:api-status:prod": "node scripts/smoke-api-status.mjs https://milady.ai https://app.milady.ai",
    "smoke:lifeops": "node scripts/smoke-lifeops.mjs",
    "ui:sync:desktop": "node scripts/sync-desktop-renderer.mjs",
    "ui:sync:desktop:watch": "node scripts/sync-desktop-renderer.mjs --watch",
    "start": "scripts/rt.sh scripts/run-node.mjs start",
    "start:desktop": "node scripts/desktop-build.mjs run --variant=base",
    "start:eliza": "bun packages/app-core/src/runtime/eliza.ts",
    "test": "node test/scripts/test-parallel.mjs",
    "test:coverage": "bunx vitest run --config vitest.unit.config.ts --coverage && node scripts/report-coverage-surfaces.mjs",
    "test:ui:playwright": "bun scripts/run-playwright.mjs apps/app test --config playwright.ui-smoke.config.ts test/ui-smoke/ui-smoke.spec.ts",
    "test:ui:playwright:packaged": "bun scripts/run-playwright.mjs apps/app test --config playwright.ui-packaged.config.ts test/ui-smoke/packaged-hash.spec.ts",
    "test:ui:playwright:settings-chat": "bun scripts/run-playwright.mjs apps/app test --config playwright.ui-smoke.config.ts test/ui-smoke/settings-chat-companion.spec.ts",
    "test:ui:testcafe": "bun run test:ui:playwright",
    "test:ui:testcafe:with-dev": "bun run test:ui:playwright",
    "test:ui:testcafe:packaged": "bun run test:ui:playwright:packaged",
    "test:ui:testcafe:settings-chat": "bun run test:ui:playwright:settings-chat",
    "test:desktop:contract": "cd apps/app/electrobun && bun run test",
    "test:desktop:packaged": "bash apps/app/electrobun/scripts/smoke-test.sh",
    "test:desktop:packaged:unsigned": "SKIP_SIGNATURE_CHECK=1 ELECTROBUN_SKIP_CODESIGN=1 bash apps/app/electrobun/scripts/smoke-test.sh",
    "test:desktop:packaged:windows": "powershell.exe -NoProfile -ExecutionPolicy Bypass -File scripts/run-windows-smoke-launcher.ps1 apps/app/electrobun/scripts/smoke-test-windows.ps1",
    "test:desktop:playwright": "node scripts/run-desktop-playwright.mjs",
    "test:desktop:playwright:windows": "cd apps/app && bunx playwright test --config playwright.electrobun.packaged.config.ts test/electrobun-packaged/electrobun-windows-startup.e2e.spec.ts",
    "test:e2e": "bunx vitest run --config vitest.e2e.config.ts --exclude packages/agent/test/anvil-contracts.e2e.test.ts --exclude packages/agent/test/apps-e2e.e2e.test.ts",
    "test:e2e:heavy": "bunx vitest run --config vitest.e2e.config.ts packages/agent/test/anvil-contracts.e2e.test.ts packages/agent/test/apps-e2e.e2e.test.ts",
    "test:e2e:validation": "bunx vitest run --config vitest.e2e.config.ts test/e2e-validation.e2e.test.ts",
    "test:e2e:coding-agents": "bunx vitest run --config vitest.e2e.config.ts packages/agent/test/agent-orchestration.e2e.test.ts packages/agent/test/coding-agent-route-readiness.e2e.test.ts packages/agent/test/coding-agent-codex-artifact.e2e.test.ts packages/agent/test/coding-agent-chat-roundtrip.e2e.test.ts",
    "test:force": "node --import tsx test/scripts/test-force.ts",
    "test:live:cloud": "node scripts/run-with-env.mjs MILADY_LIVE_TEST=1 -- bunx vitest run --config vitest.live-e2e.config.ts packages/agent/test/cloud-providers.e2e.test.ts",
    "test:live:onboarding": "node scripts/run-with-env.mjs MILADY_LIVE_TEST=1 -- bunx vitest run --config vitest.live-e2e.config.ts packages/app-core/test/app/onboarding-companion.live.e2e.test.ts",
    "test:live": "node scripts/run-with-env.mjs MILADY_LIVE_TEST=1 -- bunx vitest run --config vitest.live-e2e.config.ts packages/agent/test/wallet-live.e2e.test.ts packages/agent/test/api-auth-live.e2e.test.ts packages/agent/test/cloud-providers.e2e.test.ts",
    "test:once": "bunx vitest run",
    "test:regression-matrix:nightly": "node scripts/validate-regression-matrix.mjs --workflow nightly",
    "test:regression-matrix:pr": "node scripts/validate-regression-matrix.mjs --workflow pr",
    "test:regression-matrix:release": "node scripts/validate-regression-matrix.mjs --workflow release",
    "test:regression-matrix:release-contract": "node scripts/validate-regression-matrix.mjs --workflow release-contract",
    "test:release:contract": "node scripts/run-release-contract-suite.mjs",
    "test:startup:contract": "bunx vitest run scripts/startup-e2e-script-drift.test.ts",
    "test:startup:e2e": "bunx vitest run --config vitest.startup-e2e.config.ts packages/app-core/test/app/startup-chat.e2e.test.ts packages/app-core/test/app/startup-onboarding.e2e.test.ts packages/app-core/test/app/startup-backend-missing.e2e.test.ts packages/app-core/test/app/startup-token-401.e2e.test.ts",
    "test:watch": "bunx vitest",
    "typecheck": "tsc --noEmit",
    "db:reset": "scripts/rt.sh scripts/run-node.mjs db reset",
    "doctor": "scripts/rt.sh scripts/run-node.mjs doctor",
    "repair": "node scripts/run-repo-setup.mjs",
    "build:win": "node scripts/build-win.mjs",
    "dev:win": "node scripts/dev-win.mjs",
    "vrms:process": "node scripts/process-vrms.mjs",
    "vrms:screenshots": "node scripts/run-screenshotter.mjs"
  },
