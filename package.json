    "test:live:browser-workspace": "node scripts/run-with-env.mjs MILADY_LIVE_TEST=1 -- bunx vitest run --config vitest.live-e2e.config.ts packages/agent/test/browser-workspace-agent-chat.live.e2e.test.ts",
