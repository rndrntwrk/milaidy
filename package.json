    "test:live": "node scripts/run-with-env.mjs MILADY_LIVE_TEST=1 -- bunx vitest run --config vitest.live-e2e.config.ts packages/agent/test/wallet-live.e2e.test.ts packages/agent/test/api-auth-live.e2e.test.ts packages/agent/test/cloud-providers.e2e.test.ts packages/agent/test/lifeops-chat.live.e2e.test.ts packages/agent/test/selfcontrol-chat.live.e2e.test.ts packages/agent/test/selfcontrol-dev.live.e2e.test.ts",
