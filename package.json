    "cdn:validate": "node scripts/validate-cdn-assets.mjs",
    "cdn:manifest": "node scripts/generate-static-asset-manifest.mjs",
    "build:ios": "cd apps/app && bun scripts/build.mjs && capacitor sync ios",
