    "verify:typecheck": "tsc --noEmit",
    "verify:lint": "node scripts/run-biome-check.mjs",
    "verify:lint:fix": "node scripts/run-biome-check.mjs --write",
    "verify:format": "bunx @biomejs/biome format packages/app-core/src scripts apps",
    "verify:format:fix": "bunx @biomejs/biome format --write packages/app-core/src scripts apps",
