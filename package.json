    "test:ui:playwright": "bun scripts/run-playwright.mjs apps/app test --config playwright.ui-smoke.config.ts test/ui-smoke/ui-smoke.spec.ts test/ui-smoke/apps-session.spec.ts test/ui-smoke/browser-workspace.spec.ts",
