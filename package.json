{
  "name": "miladyai",
  "version": "2.0.0-alpha.76",
  "description": "Cute agents for the acceleration",
  "homepage": "https://github.com/milady-ai/milady",
  "author": {
    "name": "Milady AI",
    "email": "hi@milady.ai"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/milady-ai/milady.git"
  },
  "license": "MIT",
  "files": [
    "dist",
    "milady.mjs",
    "apps/app/dist",
    "scripts/rt.sh",
    "scripts/run-node.mjs",
    "scripts/patch-deps.mjs",
    "scripts/init-submodules.mjs",
    "scripts/ensure-skills.mjs",
    "scripts/ensure-avatars.mjs",
    "scripts/link-browser-server.mjs"
  ],
  "workspaces": [
    "apps/*",
    "apps/*/plugins/*",
    "apps/app/electrobun",
    "deploy/cloud-agent-template",
    "packages/*",
    "plugins/plugin-*"
  ],
  "type": "module",
  "main": "build/src/index.js",
  "bin": {
    "milady.ai": "milady.mjs",
    "milady-ai": "milady.mjs",
    "miladyai": "milady.mjs",
    "milaidy": "milady.mjs"
  },
  "exports": {
    ".": "./dist/index.js",
    "./cli-entry": "./milady.mjs",
    "./eliza": "./dist/runtime/eliza.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "benchmark:server": "node --import tsx src/benchmark/server.ts",
    "build": "tsdown && echo '{\"type\":\"module\"}' > dist/package.json && scripts/rt.sh scripts/write-build-info.ts && cd apps/app && ../../scripts/rt.sh run build",
    "install:build": "bun install --ignore-scripts && node scripts/init-submodules.mjs && node scripts/ensure-skills.mjs && node scripts/ensure-avatars.mjs && node scripts/link-browser-server.mjs && node scripts/patch-deps.mjs",
    "build:node": "tsdown && echo '{\"type\":\"module\"}' > dist/package.json && node --import tsx scripts/write-build-info.ts && cd apps/app && npm run build",
    "build:android": "cd apps/app && ../../scripts/rt.sh run build:android",
    "build:desktop": "cd apps/app && VITE_APP_VARIANT=base vite build && cd electrobun && bun run build:native-effects && bun run build",
    "build:ios": "cd apps/app && ../../scripts/rt.sh run build:ios",
    "check": "scripts/rt.sh run typecheck && scripts/rt.sh run lint",
    "db:check": "bunx vitest run src/api/database.security.test.ts src/api/database.readonly-query-guard.test.ts && bunx vitest run --config vitest.e2e.config.ts test/database-api.e2e.test.ts",
    "dev": "VITE_APP_VARIANT=full scripts/rt.sh scripts/dev-ui.mjs",
    "dev:all": "VITE_APP_VARIANT=full scripts/rt.sh scripts/dev-all.mjs",
    "dev:android": "cd apps/app && ../../scripts/rt.sh run android",
    "dev:base": "VITE_APP_VARIANT=base scripts/rt.sh scripts/dev-ui.mjs",
    "dev:companion": "VITE_APP_VARIANT=companion scripts/rt.sh scripts/dev-ui.mjs",
    "dev:full": "VITE_APP_VARIANT=full scripts/rt.sh scripts/dev-ui.mjs",
    "dev:desktop": "cd apps/app && VITE_APP_VARIANT=base vite build && cd electrobun && bun run dev",
    "dev:desktop-companion": "cd apps/app && VITE_APP_VARIANT=companion vite build && cd electrobun && bun run dev",
    "dev:desktop-full": "cd apps/app && VITE_APP_VARIANT=full vite build && cd electrobun && bun run dev",
    "dev:ios": "cd apps/app && ../../scripts/rt.sh run ios",
    "dev:ui": "VITE_APP_VARIANT=full scripts/rt.sh scripts/dev-ui.mjs --ui-only",
    "docs:bin": "scripts/rt.sh scripts/docs-list.js --build-bin",
    "docs:build": "cd docs && bun exec mint broken-links",
    "docs:dev": "cd docs && mint dev",
    "docs:list": "scripts/rt.sh scripts/docs-list.js",
    "format": "bunx @biomejs/biome format src scripts apps",
    "format:fix": "bunx @biomejs/biome format --write src scripts apps",
    "lint": "bunx @biomejs/biome check src scripts apps",
    "lint:fix": "bunx @biomejs/biome check --write src scripts apps",
    "generate:plugins": "node scripts/generate-plugin-index.js",
    "learn:loop": "echo 'Knowledge loop not yet implemented'",
    "learn:snapshot": "echo 'Knowledge snapshot not yet implemented'",
    "milady": "scripts/rt.sh scripts/run-node.mjs",
    "postinstall": "node ./scripts/init-submodules.mjs && node ./scripts/ensure-skills.mjs && node ./scripts/ensure-avatars.mjs && node ./scripts/link-browser-server.mjs && node ./scripts/patch-deps.mjs",
    "pre-review:local": "node scripts/pre-review-local.mjs",
    "prepack": "scripts/rt.sh run build",
    "prepare": "node -e \"try{require('child_process').execSync('git config core.hooksPath git-hooks',{stdio:'ignore'})}catch{}\"",
    "publish:all:next": "echo 'Use npm publish or bun publish directly'",
    "publish:plugins:next": "cd plugins && bun run publish:next",
    "release:check": "node --import tsx scripts/release-check.ts",
    "smoke:desktop": "bash apps/app/electrobun/scripts/smoke-test.sh",
    "smoke:api-status": "node scripts/smoke-api-status.mjs",
    "smoke:api-status:prod": "node scripts/smoke-api-status.mjs https://milady.ai https://app.milady.ai",
    "ui:sync:desktop": "node scripts/sync-desktop-renderer.mjs",
    "ui:sync:desktop:base": "VITE_APP_VARIANT=base node scripts/sync-desktop-renderer.mjs",
    "ui:sync:desktop:companion": "VITE_APP_VARIANT=companion node scripts/sync-desktop-renderer.mjs",
    "ui:sync:desktop:full": "VITE_APP_VARIANT=full node scripts/sync-desktop-renderer.mjs",
    "ui:sync:desktop:watch": "node scripts/sync-desktop-renderer.mjs --watch",
    "ui:sync:desktop:base:watch": "VITE_APP_VARIANT=base node scripts/sync-desktop-renderer.mjs --watch",
    "ui:sync:desktop:companion:watch": "VITE_APP_VARIANT=companion node scripts/sync-desktop-renderer.mjs --watch",
    "ui:sync:desktop:full:watch": "VITE_APP_VARIANT=full node scripts/sync-desktop-renderer.mjs --watch",
    "start": "scripts/rt.sh scripts/run-node.mjs start",
    "start:desktop": "cd apps/app && VITE_APP_VARIANT=base vite build && cd electrobun && bun run build:native-effects && bun run build && electrobun run",
    "start:eliza": "node --import tsx src/runtime/eliza.ts",
    "test": "node test/scripts/test-parallel.mjs",
    "test:coverage": "bunx vitest run --coverage",
    "test:e2e": "bunx vitest run --config vitest.e2e.config.ts",
    "test:force": "node --import tsx test/scripts/test-force.ts",
    "test:live": "MILADY_LIVE_TEST=1 bun exec vitest run --config vitest.e2e.config.ts test/wallet-live.e2e.test.ts test/api-auth-live.e2e.test.ts test/cloud-providers.e2e.test.ts",
    "test:once": "bunx vitest run",
    "test:watch": "bunx vitest",
    "typecheck": "tsc --noEmit",
    "tui": "scripts/rt.sh scripts/run-node.mjs tui",
    "tui:dev": "MILADY_PROFILE=dev scripts/rt.sh scripts/run-node.mjs --dev tui"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.13",
