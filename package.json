{
  "name": "miladyai",
  "version": "2.0.0-alpha.92",
  "description": "Cute agents for the acceleration",
  "homepage": "https://github.com/milady-ai/milady",
  "author": {
    "name": "Milady AI",
    "email": "hi@milady.ai"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/milady-ai/milady.git"
  },
  "license": "MIT",
  "files": [
    "dist",
    "milady.mjs",
    "apps/app/dist",
    "scripts/rt.sh",
    "scripts/run-node.mjs",
    "scripts/patch-deps.mjs",
    "scripts/init-submodules.mjs",
    "scripts/setup-eliza-workspace.mjs",
    "scripts/run-repo-setup.mjs",
    "scripts/ensure-skills.mjs",
    "scripts/skills",
    "scripts/ensure-avatars.mjs",
    "scripts/link-browser-server.mjs",
    "scripts/ensure-vision-deps.mjs",
    "scripts/lib/patch-bun-exports.mjs"
  ],
  "bundleDependencies": [
    "@elizaos/plugin-agent-orchestrator"
  ],
  "workspaces": [
    "apps/*",
    "apps/*/plugins/*",
    "apps/app/electrobun",
    "deploy/cloud-agent-template",
    "packages/*",
    "plugins/plugin-*"
  ],
  "type": "module",
  "main": "build/src/index.js",
  "bin": {
    "milady": "milady.mjs",
    "milady.ai": "milady.mjs",
    "milady-ai": "milady.mjs",
    "miladyai": "milady.mjs"
  },
  "exports": {
    ".": "./dist/index.js",
    "./cli-entry": "./milady.mjs",
    "./eliza": "./dist/runtime/eliza.js"
  },
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "benchmark:preflight": "node scripts/benchmark-preflight.mjs",
    "benchmark:server": "node --import tsx src/benchmark/server.ts",
    "benchmark:normalize-capture": "node --import tsx scripts/normalize-parallax-capture.ts",
    "build": "tsdown && echo '{\"type\":\"module\"}' > dist/package.json && bun scripts/write-build-info.ts && cd apps/app && bun run build",
    "build:node": "tsdown && echo '{\"type\":\"module\"}' > dist/package.json && node --import tsx scripts/write-build-info.ts && cd apps/app && npm run build",
    "build:android": "cd apps/app && bun scripts/build.mjs && capacitor sync android",
    "build:contracts": "cd test/contracts && forge build --skip Harness",
    "build:desktop": "node scripts/desktop-build.mjs build --variant=base --stage-macos-release-app",
    "build:home": "cd apps/home && bun run build",
    "build:home:desktop": "node scripts/desktop-build.mjs build --app=home --variant=base --stage-macos-release-app",
    "build:homepage": "node scripts/write-homepage-release-data.mjs && cd apps/homepage && bun run build",
    "build:ios": "cd apps/app && bun scripts/build.mjs && capacitor sync ios",
    "check": "scripts/rt.sh run typecheck && scripts/rt.sh run lint",
    "db:check": "bunx vitest run src/api/database.security.test.ts src/api/database.readonly-query-guard.test.ts && bunx vitest run --config vitest.e2e.config.ts test/database-api.e2e.test.ts",
    "dev": "scripts/rt.sh scripts/dev-ui.mjs --name=milady",
    "dev:ui": "scripts/rt.sh scripts/dev-ui.mjs --name=milady --ui-only",
    "dev:desktop": "bun scripts/dev-platform.mjs",
    "dev:android": "cd apps/app && bun scripts/build.mjs && capacitor sync android && capacitor open android",
    "dev:home": "scripts/rt.sh scripts/dev-ui.mjs --name=milady --app=home",
    "dev:home:ui": "scripts/rt.sh scripts/dev-ui.mjs --name=milady --app=home --ui-only",
    "dev:homepage": "cd apps/homepage && bun run dev",
    "dev:ios": "cd apps/app && bun scripts/build.mjs && capacitor sync ios && capacitor open ios",
    "docs:bin": "scripts/rt.sh scripts/docs-list.js --build-bin",
    "docs:build": "cd docs && bun exec mint broken-links",
    "docs:dev": "cd docs && mint dev",
    "docs:list": "scripts/rt.sh scripts/docs-list.js",
    "format": "bunx @biomejs/biome format src scripts apps",
    "format:fix": "bunx @biomejs/biome format --write src scripts apps",
    "lint": "node scripts/run-biome-check.mjs",
    "lint:fix": "node scripts/run-biome-check.mjs --write",
    "generate:plugins": "bun scripts/generate-plugin-index.js",
    "milady": "bun scripts/run-node.mjs",
    "postinstall": "node scripts/run-repo-setup.mjs",
    "pre-review:local": "bun scripts/pre-review-local.mjs",
    "prepack": "scripts/rt.sh run build",
    "prepare": "node -e \"try{require('child_process').execSync('git config core.hooksPath git-hooks',{stdio:'ignore'})}catch{}\"",
    "publish:all:next": "echo 'Use npm publish or bun publish directly'",
    "publish:plugins:next": "cd plugins && bun run publish:next",
    "release:check": "node --import tsx scripts/release-check.ts",
    "setup:eliza-workspace": "node scripts/setup-eliza-workspace.mjs",
    "smoke:desktop": "bash apps/app/electrobun/scripts/smoke-test.sh",
    "smoke:api-status": "node scripts/smoke-api-status.mjs",
    "smoke:api-status:prod": "node scripts/smoke-api-status.mjs https://milady.ai https://app.milady.ai",
    "ui:sync:desktop": "node scripts/sync-desktop-renderer.mjs",
    "ui:sync:desktop:watch": "node scripts/sync-desktop-renderer.mjs --watch",
    "start": "scripts/rt.sh scripts/run-node.mjs start",
    "start:desktop": "node scripts/desktop-build.mjs run --variant=base",
    "start:eliza": "bun src/runtime/eliza.ts",
    "test": "node test/scripts/test-parallel.mjs",
    "test:coverage": "bunx vitest run --coverage",
    "test:e2e": "bunx vitest run --config vitest.e2e.config.ts",
    "e2e": "bun run test:e2e",
    "test:force": "node --import tsx test/scripts/test-force.ts",
    "test:live": "MILADY_LIVE_TEST=1 bun exec vitest run --config vitest.e2e.config.ts test/wallet-live.e2e.test.ts test/api-auth-live.e2e.test.ts test/cloud-providers.e2e.test.ts",
    "test:once": "bunx vitest run",
    "test:watch": "bunx vitest",
    "typecheck": "tsc --noEmit",
    "tui": "scripts/rt.sh scripts/run-node.mjs tui",
    "tui:dev": "MILADY_PROFILE=dev scripts/rt.sh scripts/run-node.mjs --dev tui",
    "db:reset": "scripts/rt.sh scripts/run-node.mjs db reset",
    "doctor": "scripts/rt.sh scripts/run-node.mjs doctor",
    "repair": "node scripts/run-repo-setup.mjs",
    "build:win": "node scripts/build-win.mjs",
    "dev:win": "node scripts/dev-win.mjs",
    "vrms:process": "node scripts/process-vrms.mjs",
    "vrms:screenshots": "node scripts/run-screenshotter.mjs"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^3.0.58",
    "@ai-sdk/gateway": "^3.0.66",
    "@ai-sdk/provider": "^3.0.8",
    "@ai-sdk/provider-utils": "^4.0.19",
    "@bufbuild/protobuf": "^2.11.0",
    "@clack/prompts": "^1.1.0",
    "@electric-sql/pglite": "^0.3.16",
    "@elizaos/app-core": "alpha",
    "@elizaos/app-hyperscape": "1.0.0",
    "@elizaos/autonomous": "alpha",
    "@elizaos/core": "alpha",
    "@elizaos/prompts": "alpha",
    "@elizaos/tui": "alpha",
    "@hapi/boom": "^10.0.1",
    "@lunchtable/plugin-ltcg": "^0.1.0",
    "@mariozechner/pi-ai": "0.52.12",
    "@mariozechner/pi-tui": "0.54.0",
    "@noble/curves": "^2.0.1",
    "@opinion-labs/opinion-clob-sdk": "0.5.2",
    "@tensorflow-models/coco-ssd": "^2.2.3",
    "@tensorflow-models/mobilenet": "^2.1.1",
    "@tensorflow-models/pose-detection": "^2.1.3",
    "@tensorflow/tfjs-core": "^4.22.0",
    "@tensorflow/tfjs-node": "^4.22.0",
    "@vitest/utils": "4.1.0",
    "@whiskeysockets/baileys": "7.0.0-rc.9",
    "ai": "6.0.30",
    "bonjour-service": "^1.3.0",
    "canvas": "^3.2.1",
    "chalk": "^5.6.2",
    "chokidar": "~3.5.3",
    "cli-highlight": "^2.1.11",
    "coding-agent-adapters": "0.12.0",
    "commander": "^14.0.3",
    "cross-spawn": "^7.0.6",
    "dotenv": "^17.3.1",
    "drizzle-orm": "0.45.1",
    "ethers": "^6.16.0",
    "git-workspace-service": "0.4.4",
    "glob": "^13.0.6",
    "json5": "^2.2.3",
    "node-llama-cpp": "^3.18.1",
    "node-pty": "^1.1.0",
    "pg": "^8.20.0",
    "pino": "^10.3.1",
    "pty-manager": "1.9.8",
    "puppeteer-core": "^24.39.1",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "tar": "^6.2.1",
    "telegraf": "^4.16.3",
    "tesseract.js": "^6.0.1",
    "uuid": "^13.0.0",
    "whisper-node": "^1.1.1",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.7",
    "@types/bun": "^1.3.10",
    "@types/cross-spawn": "^6.0.6",
    "@types/node": "^25.5.0",
    "@types/pg": "^8.18.0",
    "@types/react-test-renderer": "^19.1.0",
    "@types/ws": "^8.18.1",
    "@vitest/coverage-v8": "^4.1.0",
    "react-test-renderer": "^19.2.4",
    "rimraf": "^5.0.10",
    "tsdown": "^0.20.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.0"
  },
  "overrides": {
    "drizzle-orm": "0.45.1",
    "ai": "6.0.30",
    "libsignal": "git+https://github.com/whiskeysockets/libsignal-node.git#1c30d7d7e76a3b0aa120b04dc6a26f5a12dccf67",
    "pty-manager": "1.9.8",
    "@elizaos/plugin-ollama": "2.0.0-alpha.70"
  },
  "patchedDependencies": {
    "electrobun@1.15.1": "patches/electrobun@1.15.1.patch"
  }
}