    "test:live:lifeops:scenarios": "node scripts/run-with-env.mjs MILADY_LIVE_TEST=1 MILADY_LIVE_CHAT_TEST=1 MILADY_LIVE_SCENARIO_TEST=1 -- bunx vitest run --config vitest.live-e2e.config.ts packages/agent/test/lifeops-scenarios.live.e2e.test.ts",
    "test:live:selfcontrol:chat": "node scripts/run-with-env.mjs MILADY_LIVE_TEST=1 MILADY_LIVE_CHAT_TEST=1 -- bunx vitest run --config vitest.live-e2e.config.ts packages/agent/test/selfcontrol-chat.live.e2e.test.ts",
    "test:live:selfcontrol:dev": "node scripts/run-with-env.mjs MILADY_LIVE_TEST=1 -- bunx vitest run --config vitest.live-e2e.config.ts packages/agent/test/selfcontrol-dev.live.e2e.test.ts",
