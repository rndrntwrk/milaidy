    "benchmark:evaluate": "python3 benchmarks/evaluate.py benchmarks/results/latest/",
    "benchmark:dry-run": "bun run benchmarks/run-benchmarks.ts --dry-run",
    "build": "node scripts/run-production-build.mjs",
