{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "dev",
      "runtimeExecutable": "/bin/zsh",
      "runtimeArgs": ["-l", "-c", "ELIZA_DEV_ONCHAIN=0 bun run dev"],
      "port": 2138,
      "autoPort": true
    },
    {
      "name": "dev-ui-only",
      "runtimeExecutable": "/bin/zsh",
      "runtimeArgs": ["-l", "-c", "npm run dev:ui"],
      "port": 2138,
      "autoPort": true
    },
    {
      "name": "home",
      "runtimeExecutable": "/bin/zsh",
      "runtimeArgs": ["-l", "-c", "cd apps/home && npx vite --port 2140"],
      "port": 2140
    },
    {
      "name": "homepage",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:homepage"],
      "port": 2139
    },
    {
      "name": "storybook",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "--prefix", "apps/app", "storybook"],
      "port": 6007
    },
    {
      "name": "docs",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "docs:dev"],
      "port": 3000
    }
  ]
}
