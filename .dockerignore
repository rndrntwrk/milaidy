# Default dockerignore for developer builds and the checked-in full cloud image.
# Keep workspaces required by deploy/Dockerfile in the build context so Bun can
# resolve the declared monorepo packages before the image build runs.

.git
.github
.claude
.devin
.vscode
.idea
.env
.env.local
.env.*.local
node_modules/
**/node_modules/
node_modules/.cache
apps/app/android
apps/home
apps/landing
apps/chrome-extension
apps/ui
docs/
coverage/
dev.log
install.sh
install.ps1
packaging/
artifacts/
Dockerfile
Dockerfile.alpha89
Dockerfile.fixed
Dockerfile.slim
!Dockerfile.ci
